<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="DialogFragmentStyle" parent="android:Theme.Dialog">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowEnterAnimation">@anim/anim_bottom_show</item>
        <item name="android:windowExitAnimation">@anim/anim_bottom_close</item>
        <item name="android:windowBackground">@color/transparent</item>
    </style>

    <style name="DialogFragmentBottomStyle" parent="android:Theme.Dialog">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowEnterAnimation">@anim/anim_bottom_show</item>
        <item name="android:windowExitAnimation">@anim/anim_bottom_close</item>
        <item name="android:windowBackground">@color/transparent</item>
    </style>

    <style name="Normal_Text_Style">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/color_text_title</item>
    </style>


    <!-- 弹出底部dialog样式 -->
    <style name="anim_menu_bottombar">
        <item name="android:windowEnterAnimation">@anim/anim_bottom_show</item>
        <item name="android:windowExitAnimation">@anim/anim_bottom_close</item>
    </style>

    <!-- 弹出框样式  去除黑边 -->
    <style name="Translucent.Dialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>


    <declare-styleable name="AssCardView">

        <attr name="leftShadowWidth" format="dimension" />
        <attr name="topShadowHeight" format="dimension" />
        <attr name="rightShadowWidth" format="dimension" />
        <attr name="bottomShadowHeight" format="dimension" />
        <attr name="shadowSize" format="dimension" />
        <attr name="shadowColor" format="color" />
        <attr name="shadowStartAlpha" format="integer" />
        <attr name="shadowFluidShape" format="enum">
            <enum name="adsorption" value="0" />
            <enum name="linear" value="1" />
        </attr>
        <attr name="cardBackgroundColor" format="color" />
        <attr name="cornerRadius" format="dimension" />
        <attr name="leftTopCornerRadius" format="dimension" />
        <attr name="rightTopCornerRadius" format="dimension" />
        <attr name="leftBottomCornerRadius" format="dimension" />
        <attr name="rightBottomCornerRadius" format="dimension" />
        <attr name="elevation" format="dimension" />
        <attr name="elevationAffectShadowColor" format="boolean" />
        <attr name="elevationAffectShadowSize" format="boolean" />
        <attr name="xOffset" format="dimension" />
        <attr name="yOffset" format="dimension" />
        <attr name="leftOffset" format="dimension" />
        <attr name="rightOffset" format="dimension" />
        <attr name="topOffset" format="dimension" />
        <attr name="bottomOffset" format="dimension" />
    </declare-styleable>
    <!--底部弹框动画-->
    <style name="bottomDialog">
        <item name="android:windowEnterAnimation">@anim/dialog_fr_in</item>
        <item name="android:windowExitAnimation">@anim/dialog_fr_out</item>
    </style>
    <!--scaleFade动画-->
    <style name="scaleFadeDialog">
        <item name="android:windowEnterAnimation">@anim/dialog_scale_fade_in</item>
        <item name="android:windowExitAnimation">@anim/dialog_scale_fade_out</item>
    </style>
    <!--Fade动画-->
    <style name="fadeDialog">
        <item name="android:windowEnterAnimation">@anim/dialog_fade_in</item>
        <item name="android:windowExitAnimation">@anim/dialog_fade_out</item>
    </style>

    <style name="customFragmentAnimation">
        <item name="android:windowEnterAnimation">@anim/push_left_in</item>
    </style>

    <style name="dialog" parent="@android:style/Theme.Dialog">
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:background">@color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowSoftInputMode">adjustPan</item>
    </style>

</resources>