<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <RelativeLayout
        android:id="@+id/content_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:background="#dfd">

        <View
            android:id="@+id/fake_status_bar"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            tools:background="#666"/>

        <com.baidu.baselibrary.widget.TitleBar
            android:id="@+id/titleBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/title_bar_dimen"
            android:layout_below="@+id/fake_status_bar"
            android:visibility="gone"
            app:showBackRipple="@bool/global_show_ripple"
            tools:visibility="visible"
            />

        <View
            android:id="@+id/common_list_divider"
            android:layout_below="@+id/titleBar"
            android:background="@drawable/drawable_mix_black_010"
            android:layout_width="match_parent"
            android:layout_height="0.33dp"
            android:visibility="gone"
            tools:layout_height="2dp"
            tools:visibility="visible"
            />

        <com.baidu.baselibrary.widget.CommonRefreshLayout
            android:id="@+id/refreshLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/common_list_divider">

            <com.baidu.baselibrary.widget.VerticalRecyclerView
                android:id="@+id/recyclerView"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="@dimen/padding_bottom_common_recycle"/>
        </com.baidu.baselibrary.widget.CommonRefreshLayout>

        <com.baidu.baselibrary.widget.EmptyView
            android:id="@+id/empty_view"
            android:visibility="gone"
            app:textId="@string/common_no_data"
            app:imgId="@drawable/default_no_data"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </RelativeLayout>

</layout>