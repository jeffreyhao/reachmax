<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="290dp"
    android:layout_height="wrap_content"
    android:background="@drawable/radius_white_12dp"
    tools:layout_gravity="center"
    >

    <FrameLayout
        android:layout_width="290dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/module_dialog_app_tip_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textStyle="bold"
        android:textColor="@color/pp_color_333333"
        android:textSize="17sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Title"
        />

    <TextView
        android:id="@+id/module_dialog_app_tip_content"
        android:minHeight="60dp"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:layout_marginHorizontal="20dp"
        android:gravity="start|center_vertical"
        android:textSize="14sp"
        android:textColor="@color/pp_color_666666"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:background="#cfcc"
        tools:text="content"
        />
    <androidx.legacy.widget.Space
        android:id="@+id/space"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/module_dialog_app_tip_content"
        android:layout_width="290dp"
        android:layout_height="10dp"/>
    <FrameLayout
        android:id="@+id/line"
        android:layout_width="290dp"
        android:layout_height="1dp"
        android:background="@color/pp_color_0d000000"
        app:layout_constraintTop_toBottomOf="@+id/space"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/module_dialog_app_tip_cancel"
        android:layout_width="145dp"
        android:layout_height="44dp"
        android:gravity="center"
        android:background="@drawable/bg_alert_cancel"
        android:text="@string/permission_cancel"
        android:textColor="@color/pp_color_333333"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@+id/line"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/module_dialog_app_tip_sure"
        android:layout_width="145dp"
        android:layout_height="44dp"
        android:gravity="center"
        android:layout_alignParentEnd="true"
        android:background="@drawable/common_background_confirm_button"
        android:text="@string/pp_sure"
        android:textColor="@color/color_dialog_btn_confirm"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@+id/line"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/module_dialog_app_tip_mask"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/common_radius_4d000000_12dp"
        android:layout_width="0dp"
        android:layout_height="0dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>