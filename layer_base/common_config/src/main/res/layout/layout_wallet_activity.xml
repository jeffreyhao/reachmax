<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@color/base_page_color">

    <androidx.constraintlayout.widget.Group
        android:id="@+id/group"
        android:visibility="gone"
        app:constraint_referenced_ids="rl_subscribe_info,view_space"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <include
        android:id="@+id/rl_subscribe_info"
        layout="@layout/layout_subscribe_info"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        />
    <View
        android:id="@+id/view_space"
        app:layout_constraintTop_toBottomOf="@+id/rl_subscribe_info"
        android:layout_width="match_parent"
        android:layout_height="20dp"/>

    <FrameLayout
        android:id="@+id/user_wallet_top_background"
        app:layout_constraintTop_toBottomOf="@+id/view_space"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        tools:background="#ddff" />

    <FrameLayout
        android:id="@+id/user_wallet_top_background_radius"
        android:background="@drawable/radius_background_top_right_12"
        app:layout_constraintBottom_toBottomOf="@+id/user_wallet_top_background"
        android:layout_width="match_parent"
        android:layout_height="12dp"/>

    <LinearLayout
        android:id="@+id/user_coins_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@+id/view_space"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/user_bonus_group"
        android:minHeight="53dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        tools:background="#dfdd">

        <TextView
            android:id="@+id/user_account_coins"
            android:text="*"
            android:textStyle="bold"
            android:textColor="@color/pp_color_333333"
            android:textSize="24sp"
            android:ellipsize="end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="2,800,000"/>
        <TextView
            android:textColor="@color/color_wallet_unit"
            android:textSize="13sp"
            android:ellipsize="end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/coins"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/user_bonus_group"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@+id/view_space"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/user_coins_group"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="53dp" >
        <TextView
            android:id="@+id/user_account_bonus"
            android:text="*"
            android:textStyle="bold"
            android:textColor="@color/pp_color_333333"
            android:textSize="24sp"
            android:ellipsize="end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="2,800,000"/>
        <TextView
            android:id="@+id/tv_bonus"
            android:gravity="center_vertical"
            android:textColor="@color/color_wallet_unit"
            android:textSize="13sp"
            android:ellipsize="end"
            android:drawablePadding="2dp"
            android:drawableEnd="@drawable/ic_arrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bonus"/>
    </LinearLayout>

    <TextView
        android:id="@+id/user_account_expiring_bonus"
        android:layout_marginBottom="-3dp"
        app:layout_constraintBottom_toTopOf="@+id/user_bonus_group"
        app:layout_constraintEnd_toEndOf="@+id/user_bonus_group"
        android:textColor="@color/color_top_up_pay"
        android:textSize="9sp"
        android:paddingVertical="2dp"
        android:paddingHorizontal="5dp"
        android:background="@drawable/user_wallet_bonus_tip_background"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        tools:text="600 expiring soon"
        tools:visibility="visible"
        tools:ignore="SmallSp" />

    <FrameLayout
        app:layout_constraintTop_toTopOf="@+id/user_coins_group"
        app:layout_constraintBottom_toBottomOf="@+id/user_coins_group"
        app:layout_constraintStart_toStartOf="@+id/user_coins_group"
        app:layout_constraintEnd_toEndOf="@+id/user_bonus_group"
        android:background="@color/pp_color_0d000000"
        android:layout_width="0.67dp"
        android:layout_height="36dp"/>

    <TextView
        android:id="@+id/user_wallet_top_up"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="22dp"
        android:layout_marginTop="15sp"
        android:layout_alignParentEnd="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/user_coins_group"
        app:layout_constraintBottom_toTopOf="@+id/user_wallet_top_background_radius"
        android:minHeight="44sp"
        android:background="@drawable/common_button_background"
        android:gravity="center"
        android:textStyle="bold"
        android:textColor="@color/color_top_up_pay"
        android:textSize="14sp"
        android:text="@string/top_up"/>

    <TextView
        android:id="@+id/user_wallet_top_up_tip"
        app:layout_constraintTop_toTopOf="@+id/user_wallet_top_up"
        app:layout_constraintBottom_toBottomOf="@+id/user_wallet_top_up"
        app:layout_constraintEnd_toEndOf="@+id/user_wallet_top_up"
        android:background="@drawable/user_wallet_top_up_tip_background"
        android:layout_marginEnd="8dp"
        android:paddingVertical="3dp"
        android:paddingHorizontal="15dp"
        android:textSize="12sp"
        android:textColor="@color/color_wallet_promote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        tools:visibility="visible"
        tools:text="+50%"/>

    <FrameLayout
        android:id="@+id/user_top_up_record"
        app:layout_constraintTop_toTopOf="@+id/user_wallet_top_background_radius"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <TextView
            android:layout_gravity="center_vertical|start"
            android:text="@string/top_up_record"
            android:textColor="@color/pp_color_333333"
            android:textSize="15sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <ImageView
            android:layout_gravity="center_vertical|end"
            android:background="@drawable/icon_arrow_gray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <View
            android:layout_gravity="bottom"
            android:background="@color/pp_color_0d000000"
            android:layout_width="match_parent"
            android:layout_height="0.67dp"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/user_bonus_record"
        app:layout_constraintTop_toBottomOf="@+id/user_top_up_record"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <TextView
            android:layout_gravity="center_vertical|start"
            android:text="@string/bonus_record"
            android:textColor="@color/pp_color_333333"
            android:textSize="15sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <ImageView
            android:layout_gravity="center_vertical|end"
            android:background="@drawable/icon_arrow_gray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <View
            android:layout_gravity="bottom"
            android:background="@color/pp_color_0d000000"
            android:layout_width="match_parent"
            android:layout_height="0.67dp"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/user_consumption_record"
        app:layout_constraintTop_toBottomOf="@+id/user_bonus_record"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <TextView
            android:layout_gravity="center_vertical|start"
            android:text="@string/consumption_record"
            android:textColor="@color/pp_color_333333"
            android:textSize="15sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <ImageView
            android:layout_gravity="center_vertical|end"
            android:background="@drawable/icon_arrow_gray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <View
            android:layout_gravity="bottom"
            android:background="@color/pp_color_0d000000"
            android:layout_width="match_parent"
            android:layout_height="0.67dp"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/user_book_auto_pay"
        app:layout_constraintTop_toBottomOf="@+id/user_consumption_record"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <TextView
            android:layout_gravity="center_vertical|start"
            android:text="@string/books_on_auto_purchase"
            android:textColor="@color/pp_color_333333"
            android:textSize="15sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <ImageView
            android:layout_gravity="center_vertical|end"
            android:background="@drawable/icon_arrow_gray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <View
            android:layout_gravity="bottom"
            android:background="@color/pp_color_0d000000"
            android:layout_width="match_parent"
            android:layout_height="0.67dp"/>
    </FrameLayout>


</androidx.constraintlayout.widget.ConstraintLayout>