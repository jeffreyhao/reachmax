<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:scrollbars="none">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="175dp">
        <androidx.cardview.widget.CardView
            android:id="@+id/profile_user_photo_group"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="24dp"
            android:layout_centerHorizontal="true"
            app:cardCornerRadius="50dp">
            <ImageView
                android:id="@+id/profile_user_photo"
                android:scaleType="fitXY"
                android:src="@drawable/ic_default_user"
                android:layout_width="100dp"
                android:layout_height="100dp"/>
        </androidx.cardview.widget.CardView>

        <ImageView
            android:layout_alignBottom="@+id/profile_user_photo_group"
            android:layout_alignEnd="@+id/profile_user_photo_group"
            android:layout_marginBottom="-2dp"
            android:layout_marginEnd="-4dp"
            android:visibility="gone"
            android:background="@drawable/icon_user_photo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/profile_user_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@+id/profile_user_photo_group"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="-31dp"
            android:textColor="#333333"
            android:textSize="13dp"
            tools:text="ID 1234567" />
    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="1dp"
        app:contentPaddingLeft="16dp"
        app:contentPaddingBottom="8dp"
        app:contentPaddingTop="8dp"
        app:contentPaddingRight="16dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp">
                <TextView
                    android:text="@string/pp_string_nickname"
                    android:layout_marginBottom="5dp"
                    android:layout_gravity="bottom"
                    android:textColor="@color/pp_color_333333"
                    android:textSize="13dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp">
                <com.baidu.baselibrary.widget.EditTextClear
                    android:id="@+id/profile_user_name"
                    android:textAlignment="viewStart"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@color/white"
                    android:singleLine="true"
                    android:inputType="text"
                    android:gravity="start|center_vertical"
                    android:imeOptions="actionDone"
                    android:text=""
                    android:hint="@string/enter_nickname"
                    android:textColorHint="#D2D2D2"
                    android:textColor="@color/pp_color_333333"
                    android:textStyle="bold"
                    android:textSize="16dp"/>
            </LinearLayout>
            <FrameLayout
                android:layout_gravity="bottom"
                android:background="@color/pp_color_0d000000"
                android:layout_width="match_parent"
                android:layout_height="0.67dp"/>
            <LinearLayout
                android:id="@+id/profile_user_sex_group"
                android:layout_width="match_parent"
                android:layout_height="56dp">

                <TextView
                    android:layout_weight="1"
                    android:layout_gravity="center_vertical"
                    android:text="@string/pp_string_gender"
                    android:textSize="13dp"
                    android:textColor="@color/pp_color_333333"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/profile_user_gender"
                    android:layout_gravity="center_vertical|end"
                    android:text="@string/select_gender"
                    android:textStyle="bold"
                    android:drawablePadding="6dp"
                    android:drawableEnd="@drawable/icon_arrow_gray"
                    android:textSize="16dp"
                    android:textColor="@color/pp_color_333333"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <FrameLayout
                android:layout_gravity="bottom"
                android:background="@color/pp_color_0d000000"
                android:layout_width="match_parent"
                android:layout_height="0.67dp"/>
            <LinearLayout
                android:id="@+id/profile_user_birthday_group"
                android:layout_width="match_parent"
                android:layout_height="56dp">

                <TextView
                    android:layout_weight="1"
                    android:layout_gravity="center_vertical"
                    android:text="@string/pp_string_birthday"
                    android:textSize="13dp"
                    android:textColor="@color/pp_color_333333"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/profile_user_birthday"
                    android:layout_gravity="center_vertical|end"
                    android:text="@string/select_birthday"
                    android:textStyle="bold"
                    android:drawablePadding="6dp"
                    android:drawableEnd="@drawable/icon_arrow_gray"
                    android:textSize="16dp"
                    android:textColor="@color/pp_color_333333"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <FrameLayout
                android:layout_gravity="bottom"
                android:background="@color/pp_color_0d000000"
                android:layout_width="match_parent"
                android:layout_height="0.67dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp">
                <TextView
                    android:text="@string/pp_string_email_address"
                    android:layout_marginBottom="5dp"
                    android:layout_gravity="bottom"
                    android:textColor="@color/pp_color_333333"
                    android:textSize="13dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp">
                <com.baidu.baselibrary.widget.EditTextClear
                    android:id="@+id/profile_user_email"
                    android:textAlignment="viewStart"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@color/white"
                    android:singleLine="true"
                    android:inputType="text"
                    android:gravity="start|center_vertical"
                    android:imeOptions="actionDone"
                    android:text=""
                    android:hint="@string/enter_email"
                    android:textColorHint="#D2D2D2"
                    android:textColor="@color/pp_color_333333"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

            </LinearLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/profile_submit"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="@string/pp_submit"
        android:textColor="@color/color_title_black"
        android:textSize="14dp"
        android:background="@drawable/selector_common_button_background"
        tools:background="@drawable/common_button_unable"/>

    <TextView
        android:id="@+id/copyright_tip"
        android:layout_width="match_parent"
        android:layout_height="33dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="50dp"
        android:layout_marginHorizontal="45dp"
        android:gravity="center_horizontal"
        android:textColor="@color/pp_color_999999"
        android:text="@string/login_view_tip"
        android:autoLink="web"
        android:textSize="11dp"
        tools:visibility="visible"/>
</LinearLayout>

