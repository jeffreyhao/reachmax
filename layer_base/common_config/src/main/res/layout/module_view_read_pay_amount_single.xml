<?xml version="1.0" encoding="utf-8"?>
<!--
    ReadPayView 和 ReadPayView 中的 item
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="130dp"
    android:layout_height="84dp"
    android:orientation="horizontal"
    tools:layout_gravity="center">

    <!-- 含有背景色的item -->
    <RelativeLayout
        android:id="@+id/read_pay_amount_single_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/bg_purchase_price_item"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="vertical"
            android:gravity="center">
            <!-- 金币数 -->
            <TextView
                android:id="@+id/pay_amount_single_left_amount"
                android:textStyle="bold"
                android:textColor="@color/color_pay_amount_item_coins"
                android:textSize="14dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="500 COINS" />
            <!-- bonus数 -->
            <TextView
                android:id="@+id/pay_amount_single_left_amount1"
                android:layout_marginTop="0dp"
                android:textSize="11dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/color_pay_amount_item_bonus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="+100 BONUS"
                tools:ignore="SmallSp" />
        </LinearLayout>

        <!-- 中间横向分割线 -->
        <FrameLayout
            android:id="@+id/read_pay_amount_single_line"
            android:layout_marginTop="46dp"
            android:background="@color/pp_color_0d000000"
            android:layout_width="match_parent"
            android:layout_height="0.67dp"/>

        <!-- 底部展示的价格 -->
        <TextView
            android:id="@+id/pay_amount_single_left_amount2"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_below="@+id/read_pay_amount_single_line"
            android:layout_marginBottom="2dp"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            android:textColor="@color/color_pay_amount_item_price"
            android:textSize="12dp"
            tools:text="US$ 4.99" />
    </RelativeLayout>

    <!-- 右上角tag -->
    <TextView
        android:id="@+id/pay_amount_single_left_tag"
        app:layout_constraintTop_toTopOf="@+id/read_pay_amount_single_left"
        app:layout_constraintEnd_toEndOf="@+id/read_pay_amount_single_left"
        android:layout_marginTop="-8dp"
        android:layout_marginEnd="4dp"
        android:paddingVertical="2.6dp"
        android:paddingHorizontal="6dp"
        android:textColor="@color/pp_color_FFFFFF"
        android:textSize="8sp"
        android:background="@drawable/pay_amount_tip_background"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        tools:visibility="visible"
        tools:ignore="SmallSp"
        tools:text=" +100"/>
</androidx.constraintlayout.widget.ConstraintLayout>