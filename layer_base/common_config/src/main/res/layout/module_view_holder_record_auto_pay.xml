<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingHorizontal="20dp"
    android:layout_width="match_parent"
    android:layout_height="54dp"
    tools:elevation="6dp"
    tools:background="#fff">

    <TextView
        android:id="@+id/record_auto_pay_title"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/switch_open"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/pp_color_333333"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginEnd="20dp"
        tools:text="@string/pp_update_title"/>

    <TextView
        android:id="@+id/record_auto_pay_chapter"
        android:visibility="gone"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@+id/record_auto_pay_title"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/pp_color_999999"
        android:textSize="9sp"
        tools:text="Chapter 9-20"
        tools:ignore="SmallSp" />

    <com.baidu.baselibrary.widget.SwitchButton
        android:id="@+id/switch_open"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_gravity="center_vertical|end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:thumb="@drawable/switch_ios_thumb"
        android:track="@drawable/switch_ios_track_selector"
        tools:ignore="UseSwitchCompatOrMaterialXml" />

    <View
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@color/pp_color_0d000000"
        android:layout_width="match_parent"
        android:layout_height="0.67dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>