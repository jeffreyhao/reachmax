<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    tools:layout_width="match_parent"
    tools:layout_height="match_parent"
    tools:background="#333"
    >

    <RelativeLayout
        android:id="@+id/layout_card"
        android:layout_width="300dp"
        android:layout_height="350dp"
        android:background="@drawable/bg_limit_window_premium"
        tools:layout_centerInParent="true"
        tools:elevation="6dp"
        >

        <ImageView
            android:id="@+id/iv_top"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_centerHorizontal="true"
            tools:background="1111"
            />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/iv_top"
            android:layout_centerHorizontal="true"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="22dp"
            android:gravity="center_horizontal"
            android:text="@string/limit_time_title"
            android:textColor="#962BE3"
            android:textSize="20dp"
            android:textStyle="bold|italic" />

        <cn.iwgang.countdownview.CountdownView
            android:id="@+id/cv_count_down"
            android:layout_width="wrap_content"
            android:layout_height="27dp"
            android:layout_below="@+id/tv_title"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="9dp"
            app:isHideTimeBackground="false"
            app:isShowDay="false"
            app:isShowHour="true"
            app:isShowMillisecond="false"
            app:isShowMinute="true"
            app:isShowSecond="true"
            app:isTimeTextBold="true"
            app:timeBgColor="#CA54F7"
            app:timeBgRadius="3dp"
            app:timeBgSize="30dp"
            app:timeTextColor="#01154A"
            app:timeTextSize="14dp"
            />

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_below="@+id/cv_count_down"
            android:layout_centerHorizontal="true"
            android:layout_marginHorizontal="30dp"
            android:gravity="center"
            android:text="@string/limit_time_content"
            android:textColor="#392175"
            android:textSize="12dp" />

        <RelativeLayout
            android:id="@+id/price_layout"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:layout_marginTop="166dp"
            android:layout_marginHorizontal="20dp"
            >
            <TextView
                android:id="@+id/tv_cycle"
                android:layout_width="0dp"
                android:layout_height="0dp"
                />
            <TextView
                android:id="@+id/tv_price_tip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="18dp"
                android:layout_marginHorizontal="18dp"
                android:textColor="@color/white"
                android:gravity="center"
                android:textSize="16dp"
                android:textStyle="bold"
                android:text="@string/limit_time_premium"
                />
            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_below="@+id/tv_price_tip"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="18dp"
                android:textColor="@color/white"
                android:gravity="center"
                android:textSize="15dp"
                android:textStyle="bold"
                android:text="US$19.99/week"
                />
        </RelativeLayout>


        <TextView
            android:id="@+id/tv_discount"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@+id/price_layout"
            android:layout_marginTop="-26dp"
            android:layout_marginEnd="30dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="18dp"
            android:textStyle="bold"
            android:rotation="330"
            />

        <TextView
            android:id="@+id/tv_button"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginHorizontal="30dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/bg_layout_limit_offer_button_premium"
            android:gravity="center"
            android:text="@string/subscribe_now"
            android:textColor="@color/white"
            android:textSize="18dp"
            android:textStyle="bold"
            tools:elevation="5dp"
            />


    </RelativeLayout>


    <ImageView
        android:id="@+id/iv_close"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_centerHorizontal="true"
        android:layout_below="@+id/layout_card"
        android:layout_marginTop="10dp"
        android:padding="10dp"
        android:src="@drawable/ic_close_adv_unlock"
        />

</RelativeLayout>
