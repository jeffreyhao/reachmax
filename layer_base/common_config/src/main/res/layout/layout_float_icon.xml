<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="90dp"
    android:layout_height="68dp"
    tools:background="#dddf"
    tools:layout_gravity="center"
    tools:parentTag="android.widget.RelativeLayout">

    <ImageView
        android:id="@+id/iv_img"
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:scaleType="fitXY"
        tools:src="@drawable/ic_activity_float" />
    <ImageView
        android:id="@+id/iv_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:paddingHorizontal="5dp"
        android:paddingStart="5dp"
        android:paddingEnd="7dp"
        android:paddingTop="6dp"
        android:paddingBottom="5dp"
        android:src="@drawable/ic_close_float"
        tools:background="#ccc"
        />
    <TextView
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="14.4dp"
        android:layout_marginBottom="5dp"
        android:layout_centerHorizontal="true"
        android:layout_alignBottom="@+id/iv_img"
        android:gravity="center"
        android:paddingHorizontal="5dp"
        android:background="@drawable/bg_float_time"
        android:textSize="9.5dp"
        android:textColor="@color/white"
        tools:text="00d:56h:56m:00s"
        />
</merge>