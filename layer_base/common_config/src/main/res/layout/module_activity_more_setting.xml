<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <FrameLayout
        android:id="@+id/setting_change_language"
        android:layout_width="match_parent"
        android:layout_height="53.6dp"
        android:layout_marginStart="20dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|start"
            android:text="@string/pp_language"
            android:textColor="@color/pp_color_333333"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_language"
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical|end"
            android:paddingHorizontal="20dp"
            android:drawableEnd="@drawable/icon_arrow_gray"
            android:textSize="13sp"
            android:textColor="@color/pp_color_999999"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            tools:text="English"
            />
    </FrameLayout>

    <include layout="@layout/profile_section_divider"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="0.67dp"/>

    <FrameLayout
        android:id="@+id/setting_notification"
        android:layout_width="match_parent"
        android:layout_height="53.6dp"
        android:layout_marginHorizontal="20dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|start"
            android:text="@string/pp_xml_text_22"
            android:textColor="@color/pp_color_333333"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/switch_notification"
            android:layout_gravity="center_vertical|end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumb="@drawable/switch_ios_thumb"
            android:track="@drawable/switch_ios_track_selector"
            tools:ignore="UseSwitchCompatOrMaterialXml" />
    </FrameLayout>

    <include layout="@layout/profile_section_divider"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="0.67dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="53.6dp"
        android:layout_marginHorizontal="20dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|start"
            android:text="@string/check_update"
            android:textColor="@color/pp_color_333333"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/root_app_version"
            android:text="V1.0.0"
            android:textColor="@color/pp_color_999999"
            android:textSize="13sp"
            android:layout_gravity="center_vertical|end"
            android:drawablePadding="3dp"
            android:drawableEnd="@drawable/icon_arrow_gray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>

    <include layout="@layout/profile_section_divider"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="0.67dp"/>

    <FrameLayout
        android:id="@+id/root_clear_cache"
        android:layout_width="match_parent"
        android:layout_height="53.6dp"
        android:layout_marginHorizontal="20dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|start"
            android:text="@string/clear_cache"
            android:textColor="@color/pp_color_333333"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/app_cache_size"
            android:text="14.5M"
            android:textColor="@color/pp_color_999999"
            android:textSize="13sp"
            android:layout_gravity="center_vertical|end"
            android:drawablePadding="3dp"
            android:drawableEnd="@drawable/icon_arrow_gray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>

    <include layout="@layout/profile_section_divider"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="0.67dp"/>

    <FrameLayout
        android:id="@+id/root_about_us"
        android:layout_width="match_parent"
        android:layout_height="53.6dp"
        android:layout_marginHorizontal="20dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|start"
            android:text="@string/pp_about"
            android:textColor="@color/pp_color_333333"
            android:textSize="15sp" />

        <ImageView
            android:layout_gravity="center_vertical|end"
            android:background="@drawable/icon_arrow_gray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>

    <include
        android:id="@+id/line_about_us"
        layout="@layout/profile_section_divider"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="0.67dp"/>

    <FrameLayout
        android:id="@+id/fl_del_account"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="53.6dp"
        android:layout_marginHorizontal="20dp"
        tools:visibility="visible"
        >

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_del_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|start"
            android:text="@string/pp_del_account"
            android:textColor="@color/pp_color_333333"
            android:textSize="15sp" />

        <ImageView
            android:layout_gravity="center_vertical|end"
            android:background="@drawable/icon_arrow_gray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>
    <include
        android:id="@+id/line_del_account"
        layout="@layout/profile_section_divider"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="0.67dp"/>

    <FrameLayout
        android:id="@+id/fl_more_login_methods"
        android:layout_width="match_parent"
        android:background="@drawable/common_button_background"
        android:layout_height="44dp"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="20dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/pp_more_login_methods"
            android:textColor="@color/white"
            android:textSize="15dp" />
    </FrameLayout>

</LinearLayout>
