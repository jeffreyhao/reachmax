<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:background="@drawable/bg_daily_item_miss_signed"
        android:layout_width="wrap_content"
        android:layout_height="73dp">
        <ImageView
            android:id="@+id/iv_coin"
            android:src="@drawable/ic_reward_coin3"
            android:layout_width="75dp"
            android:layout_height="73dp"/>
        <TextView
            android:id="@+id/tv_day"
            android:gravity="center_horizontal"
            android:layout_marginTop="7dp"
            android:layout_toEndOf="@+id/iv_coin"
            android:layout_alignStart="@+id/tv_coin"
            android:layout_alignEnd="@+id/tv_coin"
            android:textSize="12.67sp"
            android:textColor="@color/pp_color_999999"
            android:maxLines="1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="TUE"
            />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_coin"
            android:gravity="center_horizontal"
            android:layout_width="63dp"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="6dp"
            android:layout_toEndOf="@+id/iv_coin"
            android:maxLines="1"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="30sp"
            android:textColor="@color/colorAccent"
            android:textSize="30sp"
            android:textStyle="bold"
            tools:text="80" />
        <ImageView
            android:id="@+id/iv_check"
            android:visibility="gone"
            android:src="@drawable/ic_reward_checked"
            android:layout_centerInParent="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </RelativeLayout>
</layout>