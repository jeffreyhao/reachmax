<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:src="@drawable/ic_del_account_submitted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"/>
    <TextView
        android:text="@string/del_account_submitted"
        android:gravity="center"
        android:layout_marginHorizontal="36dp"
        android:layout_marginTop="35dp"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="@color/pp_color_333333"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/tv_confirm_time"
        android:gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="70dp"
        android:textSize="14sp"
        android:textColor="@color/pp_color_999999"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="@string/del_account_confirm_time"/>
    <TextView
        android:id="@+id/tv_get"
        android:text="@string/pp_get"
        android:gravity="center"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="50dp"
        android:textSize="14dp"
        android:textColor="@color/white"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/common_button_background"
        />
</LinearLayout>