<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/ll_del_account_submitted"
        android:visibility="gone"
        layout="@layout/layout_del_account_submitted"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        />
    <LinearLayout
        android:id="@+id/ll_head_note"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="15dp"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_delete_account_head">
        <ImageView
            android:src="@drawable/ic_del_account_warning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:layout_marginStart="13dp"
            android:text="@string/del_account_note"
            android:textSize="14sp"
            android:textColor="@color/pp_color_FF6979"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_weight="1"
        android:paddingHorizontal="15dp"
        android:layout_marginTop="15dp"
        android:layout_width="match_parent"
        android:layout_height="0dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_marginBottom="7dp"
                android:text="@string/del_account_title1"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/pp_color_333333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_marginBottom="15dp"
                android:text="@string/del_account_note1"
                android:textSize="14sp"
                android:textColor="@color/pp_color_999999"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_marginBottom="7dp"
                android:text="@string/del_account_title2"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/pp_color_333333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_marginBottom="15dp"
                android:text="@string/del_account_note2"
                android:textSize="14sp"
                android:textColor="@color/pp_color_999999"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_marginBottom="7dp"
                android:text="@string/del_account_title3"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/pp_color_333333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_marginBottom="15dp"
                android:text="@string/del_account_note3"
                android:textSize="14sp"
                android:textColor="@color/pp_color_999999"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_marginBottom="7dp"
                android:text="@string/del_account_title4"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/pp_color_333333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_marginBottom="15dp"
                android:text="@string/del_account_note4"
                android:textSize="14sp"
                android:textColor="@color/pp_color_999999"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <RelativeLayout
        android:id="@+id/rl_check"
        android:paddingHorizontal="15dp"
        android:layout_marginTop="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_select"
            android:layout_marginTop="3dp"
            android:src="@drawable/selector_terms_normal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:text="@string/read_del_account_notice_note"
            android:layout_marginStart="5dp"
            android:layout_toEndOf="@+id/iv_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </RelativeLayout>

    <TextView
        android:id="@+id/tv_del_account"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="25dp"
        android:gravity="center"
        android:text="@string/pp_del_account"
        android:textColor="@color/color_btn_delete_account_selector"
        android:textSize="15sp"
        android:background="@drawable/bg_btn_delete_account" />
</LinearLayout>