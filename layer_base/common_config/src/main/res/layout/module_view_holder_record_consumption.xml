<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="10dp"
    android:layout_marginHorizontal="20dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:id="@+id/record_consumption_coins"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textStyle="bold"
        android:textColor="@color/pp_color_333333"
        android:textSize="15sp"
        tools:text="-100 Coins"/>
    <TextView
        android:id="@+id/record_consumption_title"
        android:gravity="end"
        android:layout_marginStart="20dp"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@+id/record_consumption_coins"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/pp_color_333333"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="Billionaire’s Reborn Baby…"/>

    <TextView
        android:id="@+id/record_consumption_bonus"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/record_consumption_coins"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textStyle="bold"
        android:textColor="@color/pp_color_333333"
        android:textSize="15sp"
        tools:text="-100 Bonus"/>

    <TextView
        android:id="@+id/record_consumption_chapter"
        android:gravity="end"
        android:layout_marginStart="20dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@+id/record_consumption_title"
        app:layout_constraintStart_toEndOf="@+id/record_consumption_time"
        app:layout_constraintEnd_toEndOf="parent"
        android:singleLine="true"
        android:maxLines="1"
        android:ellipsize="middle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/pp_color_999999"
        android:textSize="12sp"
        tools:text="Chapter 9-20"
        tools:ignore="EllipsizeMaxLines,SmallSp"
        />

    <TextView
        android:id="@+id/record_consumption_time"
        android:layout_marginTop="3.6dp"
        app:layout_constraintTop_toBottomOf="@+id/record_consumption_bonus"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/pp_color_999999"
        android:textSize="12sp"
        tools:text="NOV 19, 2021 14:16:24"
        tools:ignore="SmallSp" />

    <View
        app:layout_constraintTop_toBottomOf="@+id/record_consumption_time"
        android:layout_marginTop="15dp"
        android:background="@color/pp_color_0d000000"
        android:layout_width="match_parent"
        android:layout_height="0.67dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>