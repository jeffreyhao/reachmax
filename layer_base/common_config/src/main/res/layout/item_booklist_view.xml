<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="20dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:id="@+id/iv_book_cover_card"
        android:layout_width="75dp"
        android:layout_height="99dp"
        app:cardCornerRadius="6dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" >
        <ImageView
            android:id="@+id/iv_book_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/default_bg_vertical"/>
        <View
            android:background="@drawable/book_cover_radius_2dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <com.common.config.view.BookTypeView
            android:id="@+id/bookTypeView"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:visibility="visible"
            />
    </androidx.cardview.widget.CardView>



    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/book_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="25dp"
        android:gravity="center_vertical"
        android:layout_marginStart="15dp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textSize="13dp"
        android:textColor="@color/pp_color_333333"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/iv_book_cover_card"
        app:layout_constraintTop_toTopOf="@+id/iv_book_cover_card"
        tools:text="Mr. Black"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_book_type"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="18dp"
        android:gravity="center_vertical"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/pp_color_999999"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@+id/book_name"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/book_name"
        tools:text="Romance · Completed"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/pp_color_999999"
        android:textSize="11dp"
        app:layout_constraintStart_toStartOf="@+id/tv_book_type"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_book_type"
        tools:text="Chloe Stlater is a 17-year-old werewolf wating to get her wolf…"/>

    <ImageView
        android:id="@+id/iv_book_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginTop="7dp"
        app:layout_constraintStart_toEndOf="@+id/iv_book_cover_card"
        app:layout_constraintTop_toBottomOf="@+id/tv_info"
        android:background="@drawable/icon_eye_view_all"/>

    <TextView
        android:id="@+id/tv_book_see_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="5.3dp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/pp_color_999999"
        android:textSize="11dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_info"
        app:layout_constraintStart_toEndOf="@+id/iv_book_tag"
        tools:text="39.8k" />

    <androidx.constraintlayout.widget.Group
        android:id="@+id/book_list_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:constraint_referenced_ids="iv_book_cover_card, book_name, tv_book_type, tv_info, tv_book_see_num, iv_book_tag"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_book_no_more"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/textColor6"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="@string/common_no_more"
        tools:visibility="visible"/>

</androidx.constraintlayout.widget.ConstraintLayout>
