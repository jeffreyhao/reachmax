<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="120dp"
    android:layout_height="54dp"
    android:id="@+id/root_view"
    tools:layout_gravity="center"
    tools:layout_width="110dp"
    >
    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="44dp"
        android:layout_gravity="bottom">
        <View
            android:id="@+id/read_pay_method_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/item_premium_bg_selector"
            />
        <ImageView
            android:id="@+id/pay_method_img"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/icon_google_pay"
            />
    </FrameLayout>
    <TextView
        android:id="@+id/tv_pay_extra"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:layout_marginHorizontal="10dp"
        android:layout_gravity="start"
        android:paddingHorizontal="8dp"
        android:gravity="center"
        android:textSize="11dp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/bg_selector_item_pay_method_tag"
        tools:text="+10% Bonus"
        />

</FrameLayout>

