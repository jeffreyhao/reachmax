<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="20dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="93.3dp"
    tools:background="#fff"
    tools:elevation="10dp"
    >

    <androidx.cardview.widget.CardView
        android:id="@+id/iv_book_cover_card"
        android:layout_width="70dp"
        android:layout_height="93.3dp"
        app:cardCornerRadius="6dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/iv_book_cover"
            android:layout_width="70dp"
            android:layout_height="93.3dp"
            tools:background="#cccc"/>
        <FrameLayout
            android:background="@drawable/book_cover_radius_2dp"
            android:layout_width="70dp"
            android:layout_height="93.3dp"
            />
        <TextView
            android:id="@+id/tv_short_corner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_gravity="end"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_short_corner"
            android:textColor="#654008"
            android:textSize="10dp"
            android:text="Short"
            android:visibility="gone"
            tools:visibility="visible"
            />
    </androidx.cardview.widget.CardView>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/book_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="86dp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:gravity="start"
        android:maxLines="2"
        android:textSize="14sp"
        android:textColor="@color/pp_color_333333"
        app:layout_constraintTop_toTopOf="@+id/iv_book_cover_card"
        app:layout_constraintBottom_toTopOf="@+id/tv_book_type"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="@string/pp_tip" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_book_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="86dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/pp_color_999999"
        android:textSize="12sp"
        android:layout_marginTop="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/book_name"
        app:layout_constraintBottom_toTopOf="@+id/tv_book_see_num"
        tools:text="@string/pp_tip" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_book_see_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/textColor6"
        android:textSize="12sp"
        android:layout_marginTop="6dp"
        app:layout_constraintStart_toStartOf="@+id/book_name"
        app:layout_constraintTop_toBottomOf="@+id/tv_book_type"
        app:layout_constraintBottom_toBottomOf="@+id/iv_book_cover_card"
        tools:text="39.8k" />

    <ImageView
        android:id="@+id/book_bottom_library"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@+id/tv_book_see_num"
        android:src="@drawable/read_history_icon_0"
        android:padding="4dp"
        android:layout_width="28dp"
        android:layout_height="28dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>