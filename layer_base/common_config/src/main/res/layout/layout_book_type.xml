<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tv_status"
        android:text="@string/pp_exclusive"
        android:visibility="gone"
        android:gravity="center"
        android:paddingHorizontal="5dp"
        android:paddingVertical="2dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="4sp"
        app:autoSizeMaxTextSize="8sp"
        app:autoSizeStepGranularity="1sp"
        android:maxLines="1"
        android:textSize="8sp"
        android:textColor="@color/white"
        android:background="@drawable/ic_exclusive_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:visibility="visible"
        />

    <TextView
        android:id="@+id/tv_off"
        android:visibility="gone"
        android:rotation="-40"
        android:gravity="center"
        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="4sp"
        app:autoSizeMaxTextSize="8.6sp"
        app:autoSizeStepGranularity="1sp"
        android:background="@drawable/ic_off_bg"
        android:layout_marginStart="5dp"
        android:layout_marginTop="5dp"
        android:textSize="8.6sp"
        android:textColor="@color/white"
        android:layout_width="35dp"
        android:layout_height="35dp"
        tools:text="80%\nOFF"
        tools:visibility="visible"
        tools:layout_marginStart="60dp"
        />
    <TextView
        android:id="@+id/tv_short_corner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_gravity="end"
        android:paddingHorizontal="4dp"
        android:paddingVertical="2dp"
        android:background="@drawable/bg_short_corner"
        android:textColor="#654008"
        android:textSize="10dp"
        android:text="Short"
        android:visibility="gone"
        tools:visibility="visible"
        />
</RelativeLayout>