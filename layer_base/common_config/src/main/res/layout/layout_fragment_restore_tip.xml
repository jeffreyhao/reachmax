<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/radius_white_10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="20dp"
    tools:layout_marginHorizontal="80dp"
    tools:background="#1aaa"
    tools:layout_gravity="center">

    <ImageView
        android:id="@+id/iv_close"
        android:src="@drawable/ic_reminder_close"
        android:layout_alignParentEnd="true"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:layout_marginTop="5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:visibility="gone" />

    <LinearLayout
        android:id="@+id/ll_reminder"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp">
        <ImageView
            android:id="@+id/iv_warning"
            android:visibility="gone"
            android:layout_marginEnd="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:src="@drawable/ic_warning"
            tools:visibility="visible"/>
        <TextView
            android:id="@+id/tv_reminder"
            android:text="@string/pp_friendly_reminder"
            android:textStyle="bold"
            android:textSize="19dp"
            android:textColor="@color/pp_color_333333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/ll_reminder"
        android:layout_marginHorizontal="25dp"
        android:layout_marginTop="22dp"
        android:gravity="center"
        android:textColor="@color/pp_color_666666"
        android:textSize="13dp"
        tools:text="@string/payment_pending_shoose_other" />

    <TextView
        android:id="@+id/tv_report"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_below="@+id/tv_content"
        android:layout_marginHorizontal="25dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/common_button_background"
        android:gravity="center"
        android:text="@string/pp_report_immediately"
        android:textColor="@color/color_login_earn_bonus_text"
        android:textSize="14dp" />

    <TextView
        android:id="@+id/tv_report2"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_below="@+id/tv_report"
        android:layout_marginHorizontal="25dp"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:textSize="14dp"
        android:textColor="#888888"
        android:background="@drawable/background_restore_button2"
        android:visibility="gone"
        tools:text="@string/payment_pending_keep"
        tools:visibility="visible"/>

    <TextView
        android:id="@+id/tv_bottom_tip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tv_report2"
        android:layout_marginHorizontal="25dp"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:textColor="@color/pp_color_666666"
        android:textSize="12dp"
        tools:text="@string/payment_window_bottom_tip"/>
</RelativeLayout>