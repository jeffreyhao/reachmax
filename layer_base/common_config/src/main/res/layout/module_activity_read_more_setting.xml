<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="300dp"
    android:orientation="vertical"
    android:paddingTop="18dp"
    android:paddingBottom="10dp"
    tools:background="@drawable/radius_background_top_right_12"
    tools:layout_gravity="bottom"
    tools:elevation="6dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="15dp">

        <ImageView
            android:id="@+id/read_setting_light_min"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:layout_gravity="center_vertical|start"
            android:src="@drawable/ic_light_min" />

        <SeekBar
            android:id="@+id/read_setting_light_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:max="255"
            android:maxHeight="4dp"
            android:minHeight="4dp"
            android:progress="0"
            android:progressDrawable="@drawable/seekbar_bg"
            android:thumb="@drawable/ic_seek_bar_thumb"
            android:thumbOffset="14dp"
            tools:progress="100"/>

        <SeekBar
            android:id="@+id/read_setting_light_progress_night"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:max="255"
            android:maxHeight="4dp"
            android:minHeight="4dp"
            android:progress="0"
            android:progressDrawable="@drawable/seekbar_bg_night"
            android:thumb="@drawable/ic_seek_bar_thumb_night"
            android:thumbOffset="14dp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/read_setting_light_max"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:layout_gravity="center_vertical|end"
            android:src="@drawable/ic_light_max" />
    </FrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="15dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/read_menu_font_sub"
            android:layout_width="50dp"
            android:layout_height="28dp"
            android:src="@drawable/bg_read_menu_font_size_sub"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_read_menu_font_sub"
            android:layout_width="50dp"
            android:layout_height="40dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:gravity="center"
            android:textSize="13dp"
            android:textColor="@color/pp_color_333333"
            android:text="@string/size_sub"/>

        <TextView
            android:id="@+id/read_menu_font_size"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/read_menu_font_sub"
            app:layout_constraintTop_toTopOf="parent"
            android:gravity="center"
            android:enabled="false"
            android:text="20"
            android:textColor="@color/pp_color_333333"
            android:textSize="@dimen/dp_15"
            tools:text="222"/>

        <ImageView
            android:id="@+id/read_menu_font_add"
            android:layout_width="50dp"
            android:layout_height="28dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/read_menu_font_size"
            app:layout_constraintTop_toTopOf="parent"
            android:src="@drawable/bg_read_menu_font_size_add" />

        <TextView
            android:id="@+id/tv_read_menu_font_add"
            android:layout_width="50dp"
            android:layout_height="40dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/read_menu_font_size"
            app:layout_constraintTop_toTopOf="parent"
            android:gravity="center"
            android:textSize="13dp"
            android:textColor="@color/pp_color_333333"
            android:text="@string/size_add"/>

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/bg_row_spacing3"
                android:layout_width="50dp"
                android:layout_height="28dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_read_line_space"  />

            <ImageView
                android:id="@+id/row_spacing3"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:paddingVertical="8dp"
                android:paddingHorizontal="5dp"
                android:src="@drawable/read_line_space1" />

            <View
                android:id="@+id/bg_row_spacing2"
                android:layout_width="50dp"
                android:layout_height="28dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="66dp"
                android:background="@drawable/bg_read_line_space"   />

            <ImageView
                android:id="@+id/row_spacing2"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:layout_toEndOf="@+id/row_spacing3"
                android:paddingVertical="8dp"
                android:paddingHorizontal="5dp"
                android:src="@drawable/read_line_space2" />

            <View
                android:id="@+id/bg_row_spacing1"
                android:layout_width="50dp"
                android:layout_height="28dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="126dp"
                android:background="@drawable/bg_read_line_space"  />

            <ImageView
                android:id="@+id/row_spacing1"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:layout_toEndOf="@+id/row_spacing2"
                android:paddingVertical="8dp"
                android:paddingHorizontal="5dp"
                android:src="@drawable/read_line_space3" />
        </RelativeLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp" >

        <ImageView
            android:id="@+id/bg_row_font_type1"
            android:layout_width="96dp"
            android:layout_height="30dp"
            android:layout_gravity="center_vertical|start"
            android:src="@drawable/read_check_font_background2"/>

        <TextView
            android:id="@+id/row_font_type1"
            android:layout_width="96dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical|start"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/pp_system_font"
            android:textColor="@color/pp_color_333333"
            android:textSize="@dimen/dp_13"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/bg_row_font_type2"
            android:layout_width="116dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/read_check_font_background1"/>

        <TextView
            android:id="@+id/row_font_type2"
            android:layout_width="116dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/font_merriweather"
            android:textColor="@color/pp_color_999999"
            android:textSize="@dimen/dp_13"
            android:textStyle="normal" />

        <ImageView
            android:id="@+id/bg_row_font_type3"
            android:layout_width="96dp"
            android:layout_height="30dp"
            android:layout_gravity="center_vertical|end"
            android:src="@drawable/read_check_font_background1"/>

        <TextView
            android:id="@+id/row_font_type3"
            android:layout_width="96dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical|end"
            android:gravity="center"
            android:text="@string/georgia"
            android:textColor="@color/pp_color_999999"
            android:textSize="@dimen/dp_13"
            android:textStyle="normal" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal" >

        <ImageView
            android:id="@+id/reader_bg_1"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="8dp"
            android:paddingVertical="6dp"
            android:src="@drawable/abc_reader_bg_d"/>

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/reader_bg_2"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="8dp"
            android:paddingVertical="6dp"
            android:src="@drawable/abc_reader_bg_b"/>

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/reader_bg_3"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="8dp"
            android:paddingVertical="6dp"
            android:src="@drawable/abc_reader_bg_a"/>

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/reader_bg_4"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="8dp"
            android:paddingVertical="6dp"
            android:src="@drawable/abc_reader_bg_e"/>

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/reader_bg_5"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="8dp"
            android:paddingVertical="6dp"
            android:src="@drawable/abc_reader_bg_c"/>

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp">

        <ImageView
            android:id="@+id/bg_row_flip_type1"
            android:layout_width="96dp"
            android:layout_height="30dp"
            android:layout_gravity="center_vertical|start"
            android:src="@drawable/read_check_font_background2"/>

        <TextView
            android:id="@+id/row_flip_type1"
            android:layout_width="96dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical|start"
            android:gravity="center"
            android:text="@string/pp_flip"
            android:textColor="@color/pp_color_333333"
            android:textSize="13sp"
            android:textStyle="bold" />


        <ImageView
            android:id="@+id/bg_row_flip_type2"
            android:layout_width="96dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/read_check_font_background1"/>

        <TextView
            android:id="@+id/row_flip_type2"
            android:layout_width="96dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/pp_swipe"
            android:textColor="@color/pp_color_999999"
            android:textSize="13sp"
            android:textStyle="normal" />

        <ImageView
            android:id="@+id/bg_row_flip_type3"
            android:layout_width="96dp"
            android:layout_height="30dp"
            android:layout_gravity="center_vertical|end"
            android:src="@drawable/read_check_font_background1"/>

        <TextView
            android:id="@+id/row_flip_type3"
            android:layout_width="96dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical|end"
            android:gravity="center"
            android:text="@string/pp_scroll"
            android:textColor="@color/pp_color_999999"
            android:textSize="13sp"
            android:textStyle="normal" />
    </FrameLayout>
</LinearLayout>
