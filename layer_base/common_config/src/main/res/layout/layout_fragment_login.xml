<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_login_page">
    <FrameLayout
        android:id="@+id/login_top"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_32"/>

    <FrameLayout
        android:layout_below="@+id/login_top"
        android:id="@+id/login_tool_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <ImageView
            android:id="@+id/login_close_img"
            android:padding="10dp"
            android:layout_marginEnd="10dp"
            android:layout_gravity="center_vertical|end"
            android:src="@drawable/login_icon_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>`

    <ImageView
        android:id="@+id/login_tip_logo_img"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_below="@+id/login_tool_bar"
        android:layout_centerHorizontal="true"
        android:src="@mipmap/ic_launcher"
        />

    <TextView
        android:id="@+id/login_welcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/login_tip_logo_img"
        android:layout_marginBottom="98dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="13dp"
        android:textSize="18dp"
        android:textColor="@color/color_title_black"
        android:textStyle="bold"
        tools:text="Welcome to NovelNook"/>

    <FrameLayout
        android:id="@+id/login_facebook_btn"
        android:layout_width="320dp"
        android:layout_height="44dp"
        android:layout_below="@+id/login_welcome"
        android:layout_centerHorizontal="true"
        >

        <ImageView
            android:background="@drawable/login_btn_facebook"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingStart="40dp"
            android:paddingEnd="8dp"
            android:gravity="center"
            android:text="@string/sign_in_facebook"
            android:textColor="@color/color_login_facebook_btn"
            android:textSize="14dp" />
    </FrameLayout>
    <TextView
        android:layout_marginTop="-12dp"
        android:layout_alignEnd="@+id/login_facebook_btn"
        android:layout_alignTop="@+id/login_facebook_btn"
        android:paddingHorizontal="8dp"
        android:paddingBottom="2dp"
        android:text="@string/pp_login_earn_bonus"
        android:textAllCaps="true"
        android:textSize="13dp"
        android:textColor="@color/color_login_earn_bonus_text"
        android:background="@drawable/login_earn_bonus_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <FrameLayout
        android:id="@+id/login_google_btn"
        android:layout_width="320dp"
        android:layout_height="44dp"
        android:layout_below="@+id/login_facebook_btn"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        >

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="16dp"
            android:background="@drawable/login_btn_google" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingStart="40dp"
            android:paddingEnd="8dp"
            android:gravity="center"
            android:text="@string/sign_in_google"
            android:textColor="@color/color_login_google_btn"
            android:textSize="14dp" />
    </FrameLayout>


    <TextView
        android:id="@+id/tv_terms"
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:autoLink="web"
        android:gravity="center"
        android:text="@string/login_view_tip"
        android:textSize="11dp"
        android:textColor="@color/pp_color_888888"/>


    <FrameLayout
        android:id="@+id/login_email_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@+id/tv_terms"
        android:layout_marginBottom="50dp"
        android:layout_centerHorizontal="true"
        tools:visibility="visible"
        >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textSize="11dp"
            android:textColor="@color/pp_color_999999"
            android:text="@string/login_other_methods"
            />
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:layout_gravity="center_horizontal"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_email_login"
            />
    </FrameLayout>

    <ImageView
        android:id="@+id/iv_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        />

</RelativeLayout>
