<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingHorizontal="20dp"
    android:paddingTop="19dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        app:cardCornerRadius="3dp"
        app:cardElevation="0dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_head"
            android:scaleType="fitXY"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_default_user" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_userName"
        android:gravity="center_vertical"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/cardView"
        android:textSize="15dp"
        android:textColor="@color/pp_color_999999"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        tools:text="Username"
        />
    <LinearLayout
        android:id="@+id/ll_news"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        android:layout_marginTop="3dp"
        android:layout_alignParentEnd="true"
        android:orientation="horizontal"
        android:background="@drawable/feedback_news_num_bg"
        android:layout_width="wrap_content"
        android:layout_height="24dp">
        <ImageView
            android:src="@drawable/ic_news"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/tv_num"
            android:layout_marginStart="3dp"
            android:textSize="13dp"
            android:textColor="@color/pp_color_333333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="1"
            />
    </LinearLayout>
    <TextView
        android:id="@+id/tv_new"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="5dp"
        android:layout_toStartOf="@+id/ll_news"
        android:layout_alignTop="@+id/ll_news"
        android:background="@drawable/bg_tv_new"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:textSize="8dp"
        android:textColor="@color/white"
        android:text="@string/pp_new"
        tools:visibility="visible"/>
    <TextView
        android:id="@+id/tv_content"
        android:layout_marginTop="17dp"
        android:layout_below="@+id/cardView"
        android:textSize="13dp"
        android:textColor="@color/pp_color_333333"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Friends, it’s true: the end of the decade approaches. It’s been a difficult, anxiety-provoking, morally compromised decade, but at least it’s been populated by some damn fine "
        />
    <TextView
        android:id="@+id/tv_time"
        android:layoutDirection="ltr"
        android:layout_marginTop="16dp"
        android:layout_below="@+id/tv_content"
        android:textSize="11dp"
        android:textColor="@color/pp_color_999999"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="21, Oct, 2021  23:24:58"
        />
    <TextView
        android:id="@+id/tv_issues_type"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:layout_below="@+id/tv_content"
        android:textSize="11dp"
        android:textColor="@color/pp_color_999999"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Topping up issues"
        />
    <View
        android:id="@+id/line"
        android:layout_marginTop="20dp"
        android:layout_below="@+id/tv_time"
        android:background="@color/black_percent5"
        android:layout_width="match_parent"
        android:layout_height="0.67dp"/>
</RelativeLayout>