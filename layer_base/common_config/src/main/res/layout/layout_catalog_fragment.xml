<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/catalog_root_layout"
    android:clickable="true"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/radius_ffffff_corner_top_12dp"
    android:orientation="vertical"
    tools:layout_width="300dp"
    tools:background="@drawable/bg_catalog_root" >

    <RelativeLayout
        android:id="@+id/catalog_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/radius_background_gray_12"
        android:paddingHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:background="@drawable/bg_catalog_header">

        <androidx.cardview.widget.CardView
            android:id="@+id/catalog_header_book_cover_group"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:layout_width="43dp"
            android:layout_height="57dp"
            app:cardBackgroundColor="@color/transparent"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/catalog_header_book_cover"
                android:layout_width="43dp"
                android:layout_height="57dp"
                android:src="@drawable/default_bg_vertical"/>

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/catalog_header_book_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="26dp"
            android:layout_marginEnd="20dp"
            android:layout_toEndOf="@+id/catalog_header_book_cover_group"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/pp_color_333333"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Mr. Black Is not Gentleman…"
            tools:textColor="@color/color_mix_white_050"/>

        <TextView
            android:id="@+id/catalog_header_book_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="49dp"
            android:layout_toEndOf="@+id/catalog_header_book_cover_group"
            android:textColor="@color/pp_color_999999"
            android:textSize="12sp"
            tools:text="Romance"
            tools:textColor="@color/color_mix_white_035"/>

        <ImageView
            android:id="@+id/catalog_iv_arrow"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="41dp"
            android:background="@drawable/ic_arrow"
            android:visibility="invisible"
            tools:visibility="visible" />
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/catalog_title"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:paddingHorizontal="20dp"
        android:background="@color/pp_color_0d000000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/catalog_header"  >

        <TextView
            android:id="@+id/tv_lastUpdate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:textColor="@color/pp_color_999999"
            android:textSize="13sp"
            tools:text="@string/pp_book_ongoing"
            tools:textColor="@color/color_mix_white_030" />

        <FrameLayout
            android:id="@+id/tv_line"
            android:layout_toEndOf="@+id/tv_lastUpdate"
            android:layout_marginStart="8dp"
            android:background="@color/pp_color_999999"
            android:layout_centerVertical="true"
            android:layout_width="0.67dp"
            android:layout_height="12dp"
            android:visibility="invisible"
            tools:visibility="visible"
            tools:textColor="@color/color_mix_white_030" />

        <TextView
            android:id="@+id/tv_totalCatalog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@+id/tv_line"
            android:textColor="@color/pp_color_999999"
            android:textSize="13sp"
            tools:text="55 Chapters"
            tools:textColor="@color/color_mix_white_030" />

        <ImageView
            android:id="@+id/btn_reverse"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:scaleType="center"
            android:src="@drawable/icon_sort_down"
            android:visibility="invisible"
            tools:visibility="visible"
            tools:src="@drawable/icon_sort_down_night"/>
    </RelativeLayout>

    <com.baidu.baselibrary.widget.CommonRefreshLayout
        android:id="@+id/list_swipeLayout"
        app:srlEnableNestedScrolling="false"
        app:srlEnableRefresh="false"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/catalog_title"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="vertical">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/recycler_view"
            android:scrollbars="vertical"
            android:scrollbarDefaultDelayBeforeFade="1000"
            android:layout_width="match_parent"
            android:overScrollMode="never"
            android:layout_height="match_parent"
            tools:itemCount="3"
            tools:listitem="@layout/item_bookcatalog"/>

    </com.baidu.baselibrary.widget.CommonRefreshLayout>

    <com.baidu.baselibrary.widget.EmptyView
        android:id="@+id/empty_view"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/catalog_title"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="match_parent"
        android:layout_height="0dp"/>
    <com.airbnb.lottie.LottieAnimationView
        android:id="@id/list_progress"
        app:lottie_autoPlay="false"
        app:lottie_loop="true"
        app:lottie_fileName="Loading.json"
        android:layout_width="60dp"
        android:layout_height="60dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone"
        tools:visibility="visible"/>
</androidx.constraintlayout.widget.ConstraintLayout>