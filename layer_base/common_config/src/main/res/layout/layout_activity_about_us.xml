<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pp_color_F8F8F8">


    <com.tencent.common.widget.ScaleImageView
        android:id="@+id/logo_icon"
        android:layout_width="112dp"
        android:layout_height="112dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="40dp"
        android:background="@mipmap/ic_launcher"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:viewScaleRadio="0.9"
        app:viewScaleType="width" />

    <TextView
        android:id="@+id/version_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textStyle="bold"
        android:textColor="@color/pp_color_333333"
        android:textSize="17sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/logo_icon"
        tools:text="Version 1.0.0" />

    <androidx.cardview.widget.CardView
        android:layout_marginTop="30dp"
        app:cardCornerRadius="6dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@+id/version_code"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/user_pact"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:drawableEnd="@drawable/icon_arrow_gray"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/agreement"
                android:textColor="@color/pp_color_333333"
                android:textSize="15sp"
                />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/pp_color_0d000000"
                />
            <TextView
                android:id="@+id/user_secrecy"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:drawableEnd="@drawable/icon_arrow_gray"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/privacy"
                android:textColor="@color/pp_color_333333"
                android:textSize="14sp"
                />
            <View
                android:id="@+id/usa_ad_privacy_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/pp_color_0d000000"
                android:visibility="gone"
                tools:visibility="visible"
                />
            <TextView
                android:id="@+id/tv_usa_ad_privacy"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:drawableEnd="@drawable/icon_arrow_gray"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/usa_ad_privacy"
                android:textColor="@color/pp_color_333333"
                android:textSize="14sp"
                android:visibility="gone"
                tools:visibility="visible"
                />
            <View
                android:id="@+id/config_custom_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/pp_color_0d000000"
                android:visibility="gone"
                tools:visibility="visible"
                />
            <TextView
                android:id="@+id/config_custom"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:drawableEnd="@drawable/icon_arrow_gray"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Debug Settings"
                android:textColor="@color/pp_color_333333"
                android:textSize="14sp"
                android:visibility="gone"
                tools:visibility="visible"
                />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_contact_us"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:drawableEnd="@drawable/ic_arrow"
        android:gravity="center_vertical"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:text="@string/contact_us"
        android:textColor="@color/textColor"
        android:textSize="15sp"
        android:visibility="gone"
        tools:ignore="MissingConstraints"
        tools:visibility="visible"
        />

</androidx.constraintlayout.widget.ConstraintLayout>

