<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/rl_coin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_coin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:textStyle="bold"
            android:textSize="13.3sp"
            android:textColor="@color/Cr_D2"
            tools:text="50"
            />

        <ImageView
            android:id="@+id/iv_coin"
            android:layout_width="wrap_content"
            android:layout_height="26.33dp"
            android:layout_below="@+id/tv_coin"
            android:layout_centerHorizontal="true"
            android:scaleType="fitCenter"
            tools:src="@drawable/ic_coin_daily_check" />

        <TextView
            android:id="@+id/tv_day"
            android:gravity="center"
            android:layout_marginTop="1.6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/iv_coin"
            android:layout_centerHorizontal="true"
            android:textSize="10.6sp"
            android:textColor="@color/Cr_C0"
            android:maxLines="1"
            tools:text="Day1"
            />
    </RelativeLayout>
    <View
        android:id="@+id/line"
        android:layout_toEndOf="@+id/rl_coin"
        android:layout_centerVertical="true"
        android:layout_gravity="center_vertical"
        android:background="@color/Cr_E0"
        android:layout_width="18dp"
        android:layout_height="0.5dp"/>
</RelativeLayout>
