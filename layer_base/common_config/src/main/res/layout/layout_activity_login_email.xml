<?xml version="1.0" encoding="utf-8"?>
    <RelativeLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:background="#fff"
        >

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="5dp"
            android:layout_marginTop="30dp"
            android:padding="15dp"
            android:src="@drawable/download_close"
            />

        <TextView
            android:id="@+id/tv_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/iv_close"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="50dp"
            android:textSize="26dp"
            android:textStyle="bold"
            android:textColor="@color/pp_color_222222"
            android:text="@string/email_login_top"
            />

        <TextView
            android:id="@+id/tv_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tv_top"
            android:layout_marginTop="36dp"
            android:layout_marginHorizontal="20dp"
            android:textColor="@color/pp_color_666666"
            android:textSize="14dp"
            android:text="@string/pp_email_address"
            />

        <com.baidu.baselibrary.widget.EditTextClear
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_below="@+id/tv_email"
            android:layout_marginTop="7dp"
            android:layout_marginHorizontal="20dp"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:textSize="13dp"
            android:textColor="@color/pp_color_333333"
            android:textColorHint="#C4C4C4"
            android:hint="@string/email_address_enter_tip"
            />

        <TextView
            android:id="@+id/tv_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/et_email"
            android:layout_marginTop="23dp"
            android:layout_marginHorizontal="20dp"
            android:textColor="@color/pp_color_666666"
            android:textSize="14dp"
            android:text="@string/pp_verification_code"
            />

        <TextView
            android:id="@+id/tv_get"
            android:layout_width="96dp"
            android:layout_height="44dp"
            android:layout_below="@+id/tv_code"
            android:layout_marginTop="6dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="20dp"
            android:paddingHorizontal="12dp"
            android:gravity="center"
            android:textSize="13dp"
            android:text="@string/email_send_code"
            android:enabled="false"
            />

        <EditText
            android:id="@+id/et_verify"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_toStartOf="@+id/tv_get"
            android:layout_below="@+id/tv_code"
            android:layout_marginTop="7dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="10dp"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:textSize="14.5sp"
            android:textColor="@color/color_login_verify_code"
            android:textColorHint="#C4C4C4"
            android:hint="@string/email_code_enter_tip"
            />


        <TextView
            android:id="@+id/tv_code_send_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/et_verify"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:textSize="14dp"
            android:textColor="@color/pp_color_333333"
            android:text="@string/pp_code_send_hint"
            android:visibility="gone"
            tools:visibility="visible"
            />

        <TextView
            android:id="@+id/tv_confirm"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="76dp"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/selector_common_button_background"
            android:gravity="center"
            android:text="@string/pp_confirm"
            android:enabled="false"
            />


    </RelativeLayout>

