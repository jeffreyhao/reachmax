<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    tools:layout_width="match_parent"
    tools:layout_height="match_parent"
    tools:background="#333"
    >

    <RelativeLayout
        android:id="@+id/layout_card"
        android:layout_width="300dp"
        android:layout_height="350dp"
        android:background="@drawable/bg_limit_window_common"
        tools:layout_centerInParent="true"
        tools:elevation="6dp"
        >

        <ImageView
            android:id="@+id/iv_top"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_centerHorizontal="true"
            tools:background="1111"
            />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/iv_top"
            android:layout_centerHorizontal="true"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="20dp"
            android:gravity="center_horizontal"
            android:maxLines="1"
            android:text="@string/limit_time_title"
            android:textColor="#FF5000"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12dp"
            app:autoSizeMaxTextSize="20dp"
            android:textStyle="bold|italic"
            tools:text="Limited-time offer Limited-time offer Limited-time offer"
            />

        <cn.iwgang.countdownview.CountdownView
            android:id="@+id/cv_count_down"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:layout_below="@+id/tv_title"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="6dp"
            app:isHideTimeBackground="false"
            app:isShowDay="false"
            app:isShowHour="true"
            app:isShowMillisecond="false"
            app:isShowMinute="true"
            app:isShowSecond="true"
            app:isTimeTextBold="true"
            app:timeBgColor="#4dff7651"
            app:timeBgRadius="3dp"
            app:timeBgSize="30dp"
            app:timeTextColor="#782B01"
            app:timeTextSize="14dp"
            />

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="wrap_content"
            android:layout_height="43dp"
            android:layout_below="@+id/cv_count_down"
            android:layout_centerHorizontal="true"
            android:layout_marginHorizontal="20dp"
            android:gravity="center"
            android:text="@string/limit_time_content"
            android:textColor="#782B00"
            android:textSize="12dp"
            tools:text="Vincula tu cuenta de Facebook para obtener más monedas. No te preocupes, conservarás todo tu progreso y datos actuales vinculados a esta cuenta"
            />

        <RelativeLayout
            android:id="@+id/price_layout"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:layout_marginTop="166dp"
            android:layout_marginHorizontal="20dp"
            >

            <View
                android:id="@+id/line_middle"
                android:layout_centerVertical="true"
                android:background="@drawable/white_dash_vertical"
                android:layout_width="10dp"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="113dp"
                />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="20dp"
                android:layout_toStartOf="@+id/line_middle"
                android:layout_alignTop="@+id/line_middle"
                android:layout_alignBottom="@+id/line_middle"
                android:orientation="vertical"
                android:gravity="center_vertical"
                >
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tv_coins_num"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="20dp"
                        android:textStyle="bold"
                        android:text="8400"
                        />
                    <TextView
                        android:id="@+id/tv_coins_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:paddingTop="3dp"
                        android:textColor="@color/white"
                        android:textSize="14dp"
                        android:textStyle="bold"
                        android:text="@string/coins"
                        />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tv_bonus_num"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="20dp"
                        android:textStyle="bold"
                        android:text="6720"
                        />
                    <TextView
                        android:id="@+id/tv_bonus_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:paddingTop="3dp"
                        android:textColor="@color/white"
                        android:textSize="14dp"
                        android:textStyle="bold"
                        android:text="@string/bonus"
                        />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignTop="@+id/line_middle"
                android:layout_alignBottom="@+id/line_middle"
                android:layout_marginHorizontal="12dp"
                android:orientation="vertical"
                android:gravity="center_vertical"
                tools:background="#1111"
                >

                <TextView
                    android:id="@+id/tv_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingTop="5dp"
                    android:text="US$19.99/week"
                    android:textColor="@color/white"
                    android:textSize="15dp"
                    android:textStyle="bold" />
            </LinearLayout>

        </RelativeLayout>
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_discount"
            android:layout_width="43dp"
            android:layout_height="43dp"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@+id/price_layout"
            android:layout_marginTop="-18dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/ic_limit_discount_common"
            android:gravity="center"
            android:padding="3dp"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12dp"
            app:autoSizeMaxTextSize="18dp"
            android:rotation="330"
            tools:text="30%"
            />

        <TextView
            android:id="@+id/tv_button"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginHorizontal="30dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/bg_limit_btn_common"
            android:gravity="center"
            android:text="@string/pp_pay_now"
            android:textColor="@color/white"
            android:textSize="18dp"
            android:textStyle="bold"
            tools:elevation="5dp"
            />


    </RelativeLayout>


    <ImageView
        android:id="@+id/iv_close"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_centerHorizontal="true"
        android:layout_below="@+id/layout_card"
        android:layout_marginTop="10dp"
        android:padding="10dp"
        android:src="@drawable/ic_close_adv_unlock"
        />

</RelativeLayout>