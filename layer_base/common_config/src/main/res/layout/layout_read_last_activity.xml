<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/white_top_radius10_corner"
    >

    <androidx.core.widget.NestedScrollView
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="20dp"
                android:orientation="vertical"
                android:background="@drawable/radius_f8f8f8_12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/tv_state_0"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="6dp"
                    android:textColor="@color/pp_color_999999"
                    android:textSize="16sp"
                    android:textStyle="italic"
                    tools:text="New Chapter" />
                <TextView
                    android:id="@+id/tv_state"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:textColor="@color/colorAccent"
                    android:textSize="24sp"
                    android:textStyle="italic|bold"
                    tools:text="Coming Soon" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:paddingHorizontal="20dp"
                android:paddingTop="35dp"
                android:paddingBottom="10dp"
                android:text="@string/pp_you_may_also_like"
                android:textColor="@color/pp_color_333333"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_book"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:paddingHorizontal="20dp"
                tools:itemCount="1"
                tools:listitem="@layout/item_book_end_recommend_cover"
                />
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/iv_cover"
                    android:visibility="gone"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="143dp"
                    android:layout_height="191dp"
                    tools:visibility="visible"
                    tools:src="@drawable/default_bg_vertical"/>
                <TextView
                    android:id="@+id/tv_book_name"
                    android:layout_marginTop="14.6dp"
                    android:layout_gravity="center_horizontal"
                    android:paddingHorizontal="20dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/pp_color_333333"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="书名书名"/>
                <TextView
                    android:id="@+id/tv_chapter_title"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:paddingHorizontal="20dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/pp_color_333333"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="A Secret Alpha Mate"
                    />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_chapter_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:lineSpacingExtra="5dp"
                android:textSize="15sp"
                android:textColor="@color/pp_color_666666"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="@string/login_view_tip"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:background="@color/white"
        android:elevation="5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >
        <TextView
            android:id="@+id/tv_read"
            android:text="@string/book_detail_start_reading"
            android:gravity="center"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:background="@drawable/common_button_background"
            android:layout_width="match_parent"
            android:layout_height="44dp"/>
    </LinearLayout>

</LinearLayout>
