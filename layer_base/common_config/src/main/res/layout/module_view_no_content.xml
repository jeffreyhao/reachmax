<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/error_layout"
    android:visibility="visible"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center">
    <ImageView
        android:background="@drawable/default_no_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/view_no_content_tip1"
        android:text="@string/pp_xml_no_book"
        android:textColor="@color/pp_color_999999"
        android:gravity="center"
        android:textSize="13sp"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_width="@dimen/dp_201"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/view_no_content_tip2"
        android:text="@string/pp_xml_find_novel"
        android:textColor="@color/pp_color_FF2B64"
        android:gravity="center"
        android:textSize="15sp"
        android:layout_marginTop="@dimen/dp_4"
        android:layout_width="@dimen/dp_201"
        android:layout_height="wrap_content"/>
</LinearLayout>