<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pp_color_F8F8F8">

    <ImageView
        android:id="@+id/iv_feedback"
        android:visibility="gone"
        android:layout_marginBottom="12dp"
        android:layout_centerHorizontal="true"
        android:layout_above="@+id/tv_feedback_tip"
        android:background="@drawable/icon_feedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:visibility="visible"/>

    <TextView
        android:id="@+id/tv_feedback_tip"
        android:visibility="gone"
        android:layout_centerInParent="true"
        android:text="@string/pp_tell_found"
        android:textSize="15sp"
        android:textColor="@color/pp_color_D8D8D8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:visibility="visible"/>

    <com.baidu.baselibrary.widget.CommonRefreshLayout
        android:id="@+id/refreshLayout"
        android:layout_above="@+id/feedback_send_btn"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_problem"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:itemCount="1"
            tools:listitem="@layout/item_feedback"/>
    </com.baidu.baselibrary.widget.CommonRefreshLayout>

    <TextView
        android:id="@+id/feedback_send_btn"
        android:gravity="center"
        android:textColor="@color/color_top_up_pay"
        android:layout_alignParentBottom="true"
        android:background="@color/colorAccent"
        android:text="@string/send_feedback"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_width="match_parent"
        android:layout_height="56dp"/>
</RelativeLayout>
