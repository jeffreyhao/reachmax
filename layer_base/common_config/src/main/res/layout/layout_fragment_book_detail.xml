<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp"
        android:visibility="invisible"
        android:background="@color/transparent"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include
                android:id="@+id/headerLayout"
                layout="@layout/book_detail_header_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <FrameLayout
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/expand_text_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="4"
                    android:text="Friends, it’s true: the end of the decadedecadedecadedecade approaches. It’s been a difficult, anxiety-provoking, morally compromised decade, but at least it’s been populated by some damn fine "
                    android:textColor="@color/pp_color_666666"
                    android:textSize="13dp" />

                <ImageView
                    android:id="@+id/expand_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|bottom"
                    android:background="@drawable/book_detail_see_more"
                    android:scaleType="fitEnd"
                    android:gravity="end|bottom"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </FrameLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tags"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:listitem="@layout/item_book_detail_tag"
                tools:itemCount="1"/>

            <View
                android:layout_width="match_parent"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="20dp"
                android:background="@color/pp_color_0d000000"
                android:layout_height="0.67dp"/>

            <FrameLayout
                android:id="@+id/root_catalog"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="20dp" >

                <TextView
                    android:id="@+id/tv_lastUpdate_chapterName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="80dp"
                    android:drawableStart="@drawable/icon_book_chapter_list"
                    android:drawablePadding="12dp"
                    android:lines="1"
                    android:text="Chapters (60)"
                    android:textColor="@color/pp_color_333333"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_last_update_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|end"
                    android:drawablePadding="4dp"
                    android:layout_marginEnd="16dp"
                    android:drawableEnd="@drawable/icon_arrow_gray"
                    android:includeFontPadding="false"
                    android:textColor="@color/pp_color_999999"
                    android:textSize="13sp"
                    android:text="@string/pp_book_ongoing" />
            </FrameLayout>

            <View
                android:background="@color/pp_color_0d000000"
                android:layout_width="match_parent"
                android:layout_height="8dp"/>

            <TextView
                android:id="@+id/tv_may_like"
                android:layout_marginHorizontal="20dp"
                android:gravity="bottom"
                android:layout_marginBottom="5dp"
                android:textSize="18sp"
                android:textColor="@color/pp_color_333333"
                android:textStyle="bold"
                android:text="@string/pp_you_might_like"
                android:layout_width="wrap_content"
                android:layout_height="56dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recommend"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:listitem="@layout/item_book_detail_recommend"
                tools:itemCount="1"/>

            <View
                android:id="@+id/line_recommend"
                android:layout_width="match_parent"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="20dp"
                android:background="@color/pp_color_0d000000"
                android:layout_height="0.67dp"/>

            <FrameLayout
                android:layout_marginHorizontal="20dp"
                android:layout_width="match_parent"
                android:layout_height="80dp">
                <TextView
                    android:id="@+id/book_detail_report"
                    android:layout_gravity="center_vertical"
                    android:textColor="@color/pp_color_999999"
                    android:textSize="11sp"
                    android:text="@string/book_detail_report_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </FrameLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottom_root"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:elevation="5dp"
        android:outlineProvider="bounds"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btn_start_reading"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/book_detail_read_button"
            android:layout_gravity="center_vertical"
            android:gravity="center"
            android:text="@string/book_detail_start_reading"
            android:textSize="14sp"
            android:textColor="@color/color_book_detail_read_button" />

        <ImageView
            android:id="@+id/book_detail_bottom_library_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginEnd="20dp"
            android:scaleType="center"
            android:background="@drawable/selector_bg_detail_bottom_zan"
            android:src="@drawable/selector_ic_detail_bottom_zan"
            />

    </LinearLayout>

    <View
        android:id="@+id/status_fake"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@color/white"
        android:visibility="gone"
        tools:visibility="visible"
        tools:background="#afff"/>

    <RelativeLayout
        android:id="@+id/rl_title_layout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@color/white"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:paddingHorizontal="15dp"
            android:paddingVertical="10dp"
            android:src="@drawable/icon_back_black" />

        <TextView
            android:id="@+id/toolbar_title"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:layout_marginHorizontal="120dp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/pp_color_222222"
            android:textStyle="bold"
            android:textSize="18dp"
            tools:background="@color/transparent"
            tools:visibility="visible"
            tools:text="It’s been a difficult, anxiety-provoking, morally compromised decade, but at least it’s been populated by some damn" />

        <ImageView
            android:id="@+id/btn_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="10dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="14dp"
            android:scaleType="centerInside"
            android:src="@drawable/icon_read_more"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/btn_download"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/btn_more"
            android:paddingHorizontal="6dp"
            android:paddingVertical="14dp"
            android:scaleType="centerInside"
            android:src="@drawable/icon_read_download"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/btn_download_tag"
            android:layout_width="wrap_content"
            android:layout_height="14dp"
            android:layout_marginTop="12.67dp"
            android:layout_marginEnd="-13.33dp"
            android:layout_toStartOf="@+id/btn_download"
            android:minWidth="30dp"
            android:background="@drawable/off_bg"
            android:gravity="center"
            android:text="@string/pp_off"
            android:textSize="9dp"
            android:textColor="@color/white"
            android:visibility="gone"
            tools:visibility="visible"/>


    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/rl_title_layout_stick"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:background="@color/transparent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" >

        <ImageView
            android:id="@+id/back_stick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:paddingHorizontal="15dp"
            android:paddingVertical="10dp"
            android:src="@drawable/icon_back_white"
            tools:background="#3333"/>
        <ImageView
            android:id="@+id/btn_more_stick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="10dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="14dp"
            android:scaleType="centerInside"
            android:src="@drawable/icon_setting_more_white"
            tools:background="#3333" />
    </RelativeLayout>


    <ViewStub
        android:id="@+id/stub_error_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout="@layout/layout_error"
        tools:visibility="gone"/>

    <com.baidu.baselibrary.widget.EmptyView
        android:id="@+id/empty_view"
        android:visibility="gone"
        android:clickable="true"
        app:layout_constraintTop_toBottomOf="@+id/rl_title_layout"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        tools:visibility="gone"/>

</androidx.constraintlayout.widget.ConstraintLayout>

