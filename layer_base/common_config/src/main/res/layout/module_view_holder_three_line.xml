<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="220dp"
    android:layout_height="91.3dp"
    android:paddingVertical="8dp"
    android:paddingEnd="10dp"
    tools:background="#1111"
    tools:layout_gravity="center">

    <androidx.cardview.widget.CardView
        android:id="@+id/view_holder_three_line_group"
        android:layout_width="56.7dp"
        android:layout_height="75.3dp"
        android:layout_centerVertical="true"
        app:cardCornerRadius="6dp"
        app:cardElevation="0dp">
        <ImageView
            android:id="@+id/view_holder_three_line_img"
            android:scaleType="fitXY"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
        <FrameLayout
            android:background="@drawable/book_cover_radius_2dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <TextView
            android:id="@+id/tv_short_corner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_gravity="end"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_short_corner"
            android:textColor="#654008"
            android:textSize="10dp"
            android:text="Short"
            android:visibility="gone"
            tools:visibility="visible"
            />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/view_holder_three_line_rank"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:minWidth="16dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="5.33dp"
        android:layout_toEndOf="@+id/view_holder_three_line_group"
        android:gravity="center"
        android:textColor="@color/pp_color_333333"
        android:textSize="14dp"
        android:textStyle="bold"
        tools:text="1"
        tools:visibility="visible"/>

    <TextView
        android:id="@+id/view_holder_three_line_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="2.33dp"
        android:layout_toEndOf="@+id/view_holder_three_line_rank"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/color_store_item_title"
        android:textSize="13dp"
        android:textStyle="bold"
        tools:text="@string/pp_update_title" />

    <TextView
        android:id="@+id/view_holder_three_line_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/view_holder_three_line_title"
        android:layout_marginStart="4dp"
        android:layout_marginTop="3dp"
        android:layout_toEndOf="@+id/view_holder_three_line_rank"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/color_store_item_text"
        android:textSize="12dp"
        tools:text="Romance" />

    <ImageView
        android:id="@+id/view_holder_three_line_see"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/icon_book_store0"
        android:layout_toEndOf="@+id/view_holder_three_line_rank"
        android:layout_below="@+id/view_holder_three_line_desc"
        tools:text="Romance" />

    <TextView
        android:id="@+id/view_holder_three_line_see_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginTop="2.5dp"
        android:layout_toEndOf="@+id/view_holder_three_line_see"
        android:layout_below="@+id/view_holder_three_line_desc"
        android:textColor="@color/color_store_item_text"
        android:maxLines="1"
        android:textStyle="bold"
        android:ellipsize="end"
        android:textSize="12dp"
        tools:text="33.7K" />
</RelativeLayout>