<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <RelativeLayout
        android:background="@drawable/bg_daily_item_miss_signed"
        android:layout_width="63dp"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/tv_day"
            android:layout_marginTop="6.6dp"
            android:layout_centerHorizontal="true"
            android:textSize="13.3sp"
            android:textColor="@color/pp_color_999999"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            tools:text="TUE"
            />
        <TextView
            android:id="@+id/tv_coin"
            android:layout_centerHorizontal="true"
            android:layout_below="@+id/tv_day"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@color/Cr_FF503D"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="50"
            />

        <ImageView
            android:id="@+id/iv_coin"
            android:layout_marginVertical="3dp"
            android:layout_width="34dp"
            android:layout_height="29dp"
            android:layout_below="@+id/tv_coin"
            android:layout_centerHorizontal="true"
            android:scaleType="fitXY"
            tools:src="@drawable/ic_reward_coin2" />
        <ImageView
            android:id="@+id/iv_check"
            android:visibility="gone"
            android:src="@drawable/ic_reward_checked"
            android:layout_centerInParent="true"
            android:paddingBottom="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </RelativeLayout>
</layout>