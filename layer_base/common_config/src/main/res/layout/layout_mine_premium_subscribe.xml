<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <RelativeLayout
        android:paddingHorizontal="13dp"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/ic_mine_premium_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_premium"
            android:layout_marginTop="10dp"
            android:src="@drawable/ic_premium"
            android:layout_width="90dp"
            android:layout_height="20dp"/>
        <TextView
            android:text="@string/only_1499_price"
            android:gravity="center"
            android:paddingHorizontal="4dp"
            android:layout_marginTop="10dp"
            android:layout_marginStart="7.3dp"
            android:layout_toEndOf="@+id/iv_premium"
            android:textSize="8.67sp"
            android:textColor="@color/white"
            android:background="@drawable/mine_premium_price_bg"
            android:layout_width="wrap_content"
            android:layout_height="16dp"
            tools:text="Only $14.99"
            />
        <TextView
            android:text="@string/unlimit_reading"
            android:layout_marginTop="7dp"
            android:layout_marginBottom="13dp"
            android:layout_below="@+id/iv_premium"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="@color/Cr_5F3B24"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            />
        <TextView
            android:id="@+id/tv_subscribe"
            android:text="@string/subscribe"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6.33dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:textSize="12sp"
            android:textColor="@color/color_mine_subscribe_text"
            android:background="@drawable/mine_premium_subscribe_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </RelativeLayout>
</layout>