<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="54dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    android:background="@drawable/bg_download_purchase_item"
    tools:layout_margin="20dp">

    <TextView
        android:id="@+id/purchase_single_title"
        android:layout_marginEnd="8dp"
        android:layout_toStartOf="@+id/purchase_single_off"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:maxLines="1"
        app:autoSizeTextType="uniform"
        app:autoSizeMaxTextSize="15dp"
        app:autoSizeMinTextSize="7sp"
        android:textColor="@color/pp_color_333333"
        android:textSize="15sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="@string/remaining_chapters"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/purchase_single_des"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_toStartOf="@+id/purchase_single_off"
        android:layout_below="@+id/purchase_single_title"
        android:layout_marginTop="3dp"
        android:maxLines="1"
        app:autoSizeTextType="uniform"
        app:autoSizeMaxTextSize="10sp"
        app:autoSizeMinTextSize="7sp"
        android:textColor="@color/pp_color_999999"
        android:textSize="10sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="@string/remaining_chapters"
        tools:ignore="SmallSp" />

    <TextView
        android:id="@+id/purchase_single_off"
        android:layout_marginEnd="8dp"
        android:paddingHorizontal="6dp"
        android:paddingVertical="3dp"
        android:background="@drawable/bg_download_item_off_tag"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:textColor="@color/color_top_up_pay"
        android:textSize="12sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="30% OFF"/>


</RelativeLayout>