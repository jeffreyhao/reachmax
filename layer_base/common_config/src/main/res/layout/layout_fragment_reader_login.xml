<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rl_root"
    android:layout_gravity="bottom"
    android:background="@drawable/white_top_radius10_corner"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:elevation="6dp">
    <TextView
        android:id="@+id/tv_title"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="60dp"
        android:gravity="center_horizontal"
        android:text="@string/pp_sign_in_continue"
        android:textStyle="bold"
        android:textSize="18dp"
        android:textColor="@color/pp_color_333333"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Sign to login Sign to login Sign to login  Sign to login"
        />
    <ImageView
        android:id="@+id/iv_close"
        android:paddingHorizontal="20dp"
        android:layout_alignParentEnd="true"
        android:layout_alignTop="@+id/tv_title"
        android:layout_alignBottom="@+id/tv_title"
        android:src="@drawable/icon_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <FrameLayout
        android:id="@+id/login_facebook_btn"
        android:layout_below="@+id/tv_title"
        android:layout_width="280dp"
        android:layout_height="44dp"
        android:layout_marginTop="46dp"
        android:layout_centerHorizontal="true"
        android:background="@drawable/raidus_4267b2_30dp">
        <TextView
            android:drawablePadding="8dp"
            android:drawableStart="@drawable/login_btn_facebook"
            android:layout_gravity="center"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:text="@string/sign_in_facebook"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>
    <TextView
        android:layout_marginTop="-12dp"
        android:layout_alignEnd="@+id/login_facebook_btn"
        android:layout_alignTop="@+id/login_facebook_btn"
        android:paddingHorizontal="8dp"
        android:paddingBottom="2dp"
        android:text="@string/pp_login_earn_bonus"
        android:textAllCaps="true"
        android:textSize="13sp"
        android:textColor="@color/color_login_earn_bonus_text"
        android:background="@drawable/login_earn_bonus_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <ImageView
        android:id="@+id/iv_warning"
        android:layout_marginStart="16dp"
        android:layout_alignStart="@+id/login_facebook_btn"
        android:layout_marginTop="25dp"
        android:layout_below="@+id/login_facebook_btn"
        android:src="@drawable/ic_reader_login_warning"
        android:layout_width="20dp"
        android:layout_height="20dp"/>
    <TextView
        android:id="@+id/tv_warning"
        android:text="@string/pp_reader_sign_warning"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/iv_warning"
        android:layout_marginEnd="10dp"
        android:layout_alignEnd="@+id/login_facebook_btn"
        android:layout_marginTop="-3dp"
        android:layout_alignTop="@+id/iv_warning"
        android:textSize="11sp"
        android:textColor="@color/colorPrimaryDark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:id="@+id/ll_login_method"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="114dp"
        android:layout_marginBottom="20dp"
        android:layout_below="@+id/tv_warning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_google_login"
            android:src="@drawable/ic_login_google_new"
            android:layout_width="50dp"
            android:layout_height="50dp"/>
        <ImageView
            android:id="@+id/iv_email_login"
            android:layout_marginStart="29dp"
            android:src="@drawable/ic_email_login"
            android:layout_width="50dp"
            android:layout_height="50dp"/>
    </LinearLayout>
</RelativeLayout>