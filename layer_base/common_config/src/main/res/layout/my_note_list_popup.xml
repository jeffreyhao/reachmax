<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="312dp"
    android:layout_height="320dp">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_top_triangle"
            app:tint="@color/colorAccent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            app:srcCompat="@drawable/ic_think_triangle"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/note_list"
            android:layout_below="@id/iv_top_triangle"
            android:background="@drawable/blue_round_rect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <ImageView
            android:id="@+id/iv_bottom_triangle"
            android:visibility="gone"
            app:tint="@color/colorAccent"
            android:layout_below="@id/note_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:rotation="180"
            app:srcCompat="@drawable/ic_think_triangle"/>
    </RelativeLayout>



</FrameLayout>