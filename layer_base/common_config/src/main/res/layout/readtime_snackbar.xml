<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="55dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <com.tencent.common.widget.RoundTextView
        android:id="@+id/tv_hint"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_marginStart="25dp"
        android:layout_marginEnd="27dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:textColor="@color/white"
        app:rv_isRadiusHalfHeight="true"
        tools:text="今天累计阅读10分钟，获得一个红包！"
        android:paddingStart="16dp"
        android:gravity="center_vertical"
        app:rv_backgroundColor="@color/translunt_snackbar_bg"/>
    
    <ImageView
        android:id="@+id/iv_luckymoney"
        android:src="@drawable/ic_snakbar_luckymoney"
        android:layout_width="35dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="41dp"/>
    
    <ImageView
        android:id="@+id/iv_snackbar_close"
        android:src="@drawable/ic_snackbar_close"
        android:layout_width="25dp"
        android:scaleType="center"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_height="25dp" />
</androidx.constraintlayout.widget.ConstraintLayout>