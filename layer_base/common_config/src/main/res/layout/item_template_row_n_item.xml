<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_group"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    tools:background="@color/windowBackground">

    <include
        android:id="@+id/item_template_title_layout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        layout="@layout/item_template_title_layout"
        android:visibility="gone"
        tools:visibility="visible"
        />

    <include
        android:id="@+id/row_n_item_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        layout="@layout/item_new_update_book"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="8dp"
        />


</LinearLayout>