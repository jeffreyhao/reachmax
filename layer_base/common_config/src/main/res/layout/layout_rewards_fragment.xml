<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_rewards"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base_page_color"
    tools:background="#ccc"
    >


    <RelativeLayout
        android:id="@+id/rewards_title_bar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        tools:layout_marginTop="30dp"
        tools:layout_height="@dimen/dp_32">

        <ImageView
            android:id="@+id/iv_back"
            android:tag="arrow"
            android:paddingHorizontal="20dp"
            android:src="@drawable/ic_back"
            android:layout_width="wrap_content"
            android:layout_height="50dp" />

        <TextView
            android:id="@+id/tv_title"
            android:text="@string/rewards"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/color_title_black"
            android:layout_width="wrap_content"
            android:layout_height="50dp" />
        <TextView
            android:id="@+id/tv_rules"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="15dp"
            android:layout_marginStart="15dp"
            android:drawablePadding="3dp"
            android:drawableStart="@drawable/rules_hint"
            android:gravity="center"
            android:textSize="13sp"
            android:textColor="@color/color_title_black"
            android:text="@string/pp_rules" />

    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/rewards_title_bar"
        android:layout_marginTop="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="15dp"
            android:orientation="vertical">


            <FrameLayout
                android:id="@+id/fl_check"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/layout_daily_check"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/radius_white_12dp"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible" >

                    <TextView
                        android:id="@+id/tv_daily_check"
                        android:layout_width="match_parent"
                        android:layout_height="53dp"
                        android:gravity="center_vertical"
                        android:paddingStart="15dp"
                        android:text="@string/pp_daily_check"
                        android:textColor="@color/color_title_black"
                        android:textSize="15dp"
                        android:textStyle="bold"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.3dp"
                        android:background="@drawable/drawable_mix_black_005"
                        tools:layout_height="2dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_check"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:overScrollMode="never"
                        android:paddingStart="16dp"
                        android:paddingTop="13.3dp"
                        android:paddingBottom="20dp"
                        android:scrollbars="none"
                        android:visibility="gone"
                        tools:itemCount="1"
                        tools:listitem="@layout/item_daily_sign_more_coin"
                        tools:visibility="visible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_check_login"
                    android:layout_width="match_parent"
                    android:layout_height="251dp"
                    android:background="@drawable/radius_white_12dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:layout_marginTop="180dp"
                    tools:visibility="visible">
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="35"/>
                    <ImageView
                        android:layout_width="43dp"
                        android:layout_height="43dp"
                        android:src="@drawable/ic_check_lock" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="20"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="70dp"
                        android:gravity="center"
                        android:text="@string/pp_reward_signin_hint"
                        android:textColor="@color/color_title_black"
                        android:textSize="16dp"
                        tools:text="Войдите и наслаждайтесь дополнительными бесплатными преимуществами"/>
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="35"/>
                    <TextView
                        android:id="@+id/tv_sign_in"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="@drawable/common_button_background"
                        android:gravity="center"
                        android:text="@string/pp_sign_in"
                        android:textColor="@color/white"
                        android:textSize="15dp" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="35"/>
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/layout_novice_tasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/radius_white_12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_novice_tasks"
                    android:layout_width="match_parent"
                    android:layout_height="53dp"
                    android:gravity="center_vertical"
                    android:paddingStart="15dp"
                    android:text="@string/pp_novice_tasks"
                    android:textColor="@color/color_title_black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <View
                    android:id="@+id/line1"
                    android:layout_width="match_parent"
                    android:layout_height="0.3dp"
                    android:layout_below="@+id/tv_novice_tasks"
                    android:background="@drawable/drawable_mix_black_005"
                    android:visibility="gone"
                    tools:layout_height="2dp"
                    tools:visibility="visible" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_novice_task"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/line1"
                    android:overScrollMode="never"
                    android:scrollbars="none"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_task_info" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_daily_tasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/radius_white_12dp"
                android:orientation="vertical" >

                <TextView
                    android:id="@+id/tv_daily_tasks"
                    android:layout_width="match_parent"
                    android:layout_height="53dp"
                    android:layout_below="@+id/rv_novice_task"
                    android:gravity="bottom"
                    android:paddingStart="15dp"
                    android:paddingBottom="11dp"
                    android:text="@string/pp_daily_tasks"
                    android:textColor="@color/color_title_black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <View
                    android:id="@+id/line2"
                    android:layout_width="match_parent"
                    android:layout_height="0.3dp"
                    android:layout_below="@+id/tv_daily_tasks"
                    android:background="@drawable/drawable_mix_black_005"
                    android:visibility="gone"
                    tools:layout_height="2dp"
                    tools:visibility="visible" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_daily_task"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/line2"
                    android:overScrollMode="never"
                    android:scrollbars="none"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_task_info" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.baidu.baselibrary.widget.EmptyView
        android:id="@+id/empty_view"
        android:visibility="gone"
        android:layout_below="@+id/rewards_title_bar"
        app:imgId="@drawable/default_no_net"
        app:textId="@string/error_net_tip"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</RelativeLayout>