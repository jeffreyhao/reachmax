<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:ignore="MissingDefaultResource"
    >
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:textColor="@color/black"
            android:textSize="18dp"
            android:text="我的"
            />
        <View
            android:layout_width="match_parent"
            android:layout_height="0.33dp"
            android:background="@color/divider_line_color"
            />
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="22dp"
            >
            <androidx.cardview.widget.CardView
                android:id="@+id/card_avatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/transparent"
                >
                <ImageView
                    android:id="@+id/iv_user_avatar"
                    android:scaleType="fitXY"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#295D8C"
                    />
                <TextView
                    android:id="@+id/tv_user_word"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="@color/white"
                    android:textSize="30dp"
                    tools:text="H"
                    />
            </androidx.cardview.widget.CardView>
            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="100dp"
                android:layout_gravity="center_vertical"
                android:textColor="@color/black"
                android:textSize="18dp"
                android:text="用户名"
                />
        </FrameLayout>
        <RelativeLayout
            android:id="@+id/info_layout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:paddingHorizontal="20dp"
            android:background="@drawable/bg_transparent_press"
            >
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_mine_info"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:text="个人信息"
                android:layout_centerVertical="true"
                android:textColor="@color/pp_color_333333"
                android:textSize="15dp"
                />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginTop="5dp"
                android:background="@drawable/ic_arrow_1"
                />
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/task_layout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:paddingHorizontal="20dp"
            android:background="@drawable/bg_transparent_press"
            >
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_mine_task"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:text="任务中心"
                android:layout_centerVertical="true"
                android:textColor="@color/pp_color_333333"
                android:textSize="15dp"
                />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginTop="5dp"
                android:background="@drawable/ic_arrow_1"
                />
        </RelativeLayout>
    </LinearLayout>
</layout>
