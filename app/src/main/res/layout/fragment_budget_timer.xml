<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:ignore="MissingDefaultResource">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/radius_ffffff_corner_top_12dp"
        tools:layout_gravity="bottom"
        tools:elevation="10dp"
        >
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginVertical="16dp"
            android:textColor="@color/black"
            android:textSize="16dp"
            android:text="定时任务"
            />
        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="10dp"
            android:padding="8dp"
            android:background="@drawable/bg_ripple_circle"
            android:src="@drawable/ic_close_pay"
            />
        <TextView
            android:id="@+id/text_task_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="8dp"
            android:layout_marginStart="15dp"
            android:layout_below="@+id/tv_title"
            android:textColor="@color/black"
            android:textSize="16dp"
            android:text="任务名称"
            />
        <TextView
            android:id="@+id/tv_task_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/text_task_name"
            android:layout_marginHorizontal="15dp"
            android:background="@drawable/bg_filter_box"
            android:paddingHorizontal="15dp"
            android:paddingVertical="13dp"
            android:textColor="@color/black"
            android:textSize="12dp"
            tools:text="广告系列_EN_andr_aeo_1U19940_The Mafia Princess' 9 Brothers_1030-国家-年龄_李四_20241114"
            />
        <TextView
            android:id="@+id/text_time_zone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="15dp"
            android:layout_below="@+id/tv_task_name"
            android:textColor="@color/black"
            android:textSize="16dp"
            android:text="时区"
            />
        <TextView
            android:id="@+id/tv_time_zone"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_below="@+id/text_time_zone"
            android:layout_marginStart="15dp"
            android:background="@drawable/bg_radius_button"
            android:paddingHorizontal="12dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="11dp"
            android:text="账户时区"
            />
        <TextView
            android:id="@+id/text_timer_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="15dp"
            android:layout_below="@+id/tv_time_zone"
            android:textColor="@color/black"
            android:textSize="16dp"
            android:text="定时器类型"
            />
        <TextView
            android:id="@+id/tv_timer_type"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_below="@+id/text_timer_type"
            android:layout_marginStart="15dp"
            android:background="@drawable/bg_radius_button"
            android:paddingHorizontal="12dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="11dp"
            android:text="一次性"
            />
        <TextView
            android:id="@+id/text_budget_setting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="15dp"
            android:layout_below="@+id/tv_timer_type"
            android:textColor="@color/black"
            android:textSize="16dp"
            android:text="*预算"
            />
        <EditText
            android:id="@+id/et_timer_budget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/text_budget_setting"
            android:layout_marginHorizontal="15dp"
            android:background="@drawable/selector_date_press_btn"
            android:paddingHorizontal="15dp"
            android:paddingVertical="13dp"
            android:gravity="center_vertical"
            android:textColor="@color/black"
            android:textSize="12dp"
            android:textColorHint="@color/pp_color_999999"
            android:inputType="number"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:hint="0"
            />
        <TextView
            android:id="@+id/text_timer_setting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="15dp"
            android:layout_below="@+id/et_timer_budget"
            android:textColor="@color/black"
            android:textSize="16dp"
            android:text="定时器设置"
            />
        <TextView
            android:id="@+id/tv_timer_setting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/text_timer_setting"
            android:layout_marginHorizontal="15dp"
            android:background="@drawable/selector_date_press_btn"
            android:paddingHorizontal="15dp"
            android:paddingVertical="13dp"
            android:drawableLeft="@drawable/ic_timer"
            android:drawablePadding="5dp"
            android:gravity="center_vertical"
            android:textColor="@color/black"
            android:textSize="12dp"
            android:textColorHint="@color/pp_color_999999"
            android:hint="点击设置定时器"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_below="@+id/tv_timer_setting"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="52dp"
            android:layout_marginBottom="25dp"
            >
            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:background="@drawable/selector_button_box_press"
                android:gravity="center"
                android:textSize="13dp"
                android:textColor="@color/color_selector_btn_task_cancel"
                android:text="取消任务"
                android:enabled="false"
                />
            <TextView
                android:id="@+id/btn_submit"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/selector_radius_button_press"
                android:gravity="center"
                android:textSize="13dp"
                android:textColor="@color/white"
                android:text="确认修改"
                />
        </LinearLayout>
    </RelativeLayout>
</layout>
