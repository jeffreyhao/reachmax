<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:background="#fff"
        tools:elevation="10dp"
        tools:layout_marginTop="10dp"
        >
        <View
            android:id="@+id/item_adv_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_line_color"
            />
        <View
            android:id="@+id/top_right"
            android:layout_width="10dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            />
        <com.baidu.baselibrary.widget.SwitchButton
            android:id="@+id/adv_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/top_right"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="8dp"
            android:padding="2dp"
            android:thumb="@drawable/switch_thumb"
            android:track="@drawable/switch_track_selector"
            android:checked="true"
            tools:background="#cccc"
            />
        <TextView
            android:id="@+id/tv_adv_state"
            android:layout_width="wrap_content"
            android:layout_height="16dp"
            android:layout_toStartOf="@+id/adv_switch"
            android:layout_gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="10dp"
            android:paddingHorizontal="6dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="10dp"
            tools:background="@drawable/bg_task_state_finish"
            tools:text="投放中"
            />
        <LinearLayout
            android:id="@+id/layout_adv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/tv_adv_state"
            android:layout_marginTop="12dp"
            android:layout_marginStart="10dp"
            android:orientation="horizontal"
            >
            <com.baidu.baselibrary.widget.CheckBox
                android:id="@+id/tv_check_box"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_selector_check_box"
                android:textSize="13dp"
                android:checked="true"
                android:visibility="gone"
                tools:visibility="visible"
                />
            <com.xcyh.reachmax.app.meta.ui.widget.LongTouchTextView
                android:id="@+id/tv_adv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingVertical="8dp"
                android:paddingHorizontal="5dp"
                android:background="@drawable/selector_button_transparent_press"
                android:gravity="center_vertical"
                android:textStyle="bold"
                android:textColor="@color/colorAccent"
                android:textSize="14dp"
                android:text="新应用推广广告组新应用推广广告组新应用推广广告组"
                />
        </LinearLayout>
        <TextView
            android:id="@+id/tv_adv_no"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/layout_adv_name"
            android:layout_marginStart="15dp"
            android:background="@color/transparent"
            android:textColor="@color/pp_color_666666"
            android:textSize="13dp"
            android:text="120212787122270314"
            />
        <ImageView
            android:id="@+id/iv_copy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/layout_adv_name"
            android:layout_marginTop="-8dp"
            android:layout_marginStart="2dp"
            android:layout_toEndOf="@+id/tv_adv_no"
            android:background="@color/transparent"
            android:padding="10dp"
            android:src="@drawable/ic_copy"
            />
        <GridLayout
            android:id="@+id/gl_adv_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_below="@+id/tv_adv_no"
            android:columnCount="3"
            android:rowCount="6"
            >
            <TextView
                android:id="@+id/tv_text_spend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="0"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="15dp"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="消耗"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="0"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="15dp"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="安装数量/成本"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="0"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="15dp"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="充值金额"
                />
            <TextView
                android:id="@+id/tv_spend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="1"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="6dp"
                android:gravity="center"
                android:textColor="@color/pp_color_666666"
                android:textSize="12dp"
                tools:text="$3000"
                />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="1"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:gravity="center"
                >
                <TextView
                    android:id="@+id/tv_install_volume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:paddingTop="6dp"
                    android:gravity="center"
                    android:textColor="@color/pp_color_666666"
                    android:textSize="12dp"
                    tools:text="175/"
                    />
                <TextView
                    android:id="@+id/tv_install_cost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:paddingTop="6dp"
                    android:gravity="center"
                    android:textColor="@color/pp_color_666666"
                    android:textSize="12dp"
                    tools:text="$3000"
                    />
            </LinearLayout>
            <TextView
                android:id="@+id/tv_recharge_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="1"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="6dp"
                android:gravity="center"
                android:textColor="@color/pp_color_666666"
                android:textSize="12dp"
                tools:text="$30.00"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="2"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="20dp"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="ROI"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="2"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="20dp"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="CPM"
                />
            <TextView
                android:id="@+id/tv_cpm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="3"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="6dp"
                android:gravity="center"
                android:textColor="@color/pp_color_666666"
                android:textSize="12dp"
                tools:text="$3500"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="2"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="20dp"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="CPC"
                />
            <TextView
                android:id="@+id/tv_cpc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="3"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="6dp"
                android:gravity="center"
                android:textColor="@color/pp_color_666666"
                android:textSize="12dp"
                tools:text="$3800"
                />

            <TextView
                android:id="@+id/tv_roi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="3"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="6dp"
                android:gravity="center"
                android:textColor="@color/pp_color_666666"
                android:textSize="12dp"
                tools:text="$3000"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_row="4"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="20dp"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="购物数量/成本"
                />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="5"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:gravity="center"
                >
                <TextView
                    android:id="@+id/tv_buy_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@color/transparent"
                    android:paddingTop="6dp"
                    android:gravity="center"
                    android:textColor="@color/pp_color_666666"
                    android:textSize="12dp"
                    tools:text="175/"
                    />
                <TextView
                    android:id="@+id/tv_buy_cost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@color/transparent"
                    android:paddingTop="6dp"
                    android:gravity="center"
                    android:textColor="@color/pp_color_666666"
                    android:textSize="12dp"
                    tools:text="$3000"
                    />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_row="4"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:background="@color/transparent"
                android:paddingTop="20dp"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="点击量/点击率"
                />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="5"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:gravity="center"
                >
                <TextView
                    android:id="@+id/tv_click_volume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@color/transparent"
                    android:paddingTop="6dp"
                    android:gravity="center"
                    android:textColor="@color/pp_color_666666"
                    android:textSize="12dp"
                    tools:text="175/"
                    />
                <TextView
                    android:id="@+id/tv_click_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@color/transparent"
                    android:paddingTop="6dp"
                    android:gravity="center"
                    android:textColor="@color/pp_color_666666"
                    android:textSize="12dp"
                    tools:text="$3000"
                    />
            </LinearLayout>

            <TextView
                android:id="@+id/text_independent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="4"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:paddingTop="20dp"
                android:background="@color/transparent"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="购物人数/成本\n（独立用户）"
                />
            <LinearLayout
                android:id="@+id/independent_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_row="5"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:paddingTop="6dp"
                android:gravity="center"
                >
                <TextView
                    android:id="@+id/tv_independent_persons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:gravity="center"
                    android:textColor="@color/pp_color_666666"
                    android:textSize="12dp"
                    tools:text="176/"
                    />
                <TextView
                    android:id="@+id/tv_independent_cost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:gravity="center"
                    android:textColor="@color/pp_color_666666"
                    android:textSize="12dp"
                    tools:text="$3000"
                    />
            </LinearLayout>
        </GridLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_below="@+id/gl_adv_data"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="20dp"
            android:layout_marginEnd="15dp"
            android:gravity="end"
            >
            <TextView
                android:id="@+id/btn_more"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="@drawable/selector_item_btn"
                android:gravity="center"
                android:textSize="12dp"
                android:textColor="@color/colorAccent"
                android:text="更多"
                />
            <LinearLayout
                android:id="@+id/btn_budget_timer"
                android:layout_width="92dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:background="@drawable/selector_item_btn"
                android:gravity="center"
                android:orientation="horizontal"
                tools:enabled="false"
                >
                <ImageView
                    android:id="@+id/iv_timer_budget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_timer_left"
                    android:paddingTop="2dp"
                    android:paddingEnd="3dp"
                    />

                <TextView
                    android:id="@+id/tv_budget_timer_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="定时改预算"
                    android:textColor="@color/color_selector_budget_btn"
                    android:textSize="12dp"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/btn_switch_timer"
                android:layout_width="88dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:background="@drawable/selector_item_btn"
                android:gravity="center"
                android:orientation="horizontal"
                tools:enabled="false"
                >
                <ImageView
                    android:id="@+id/iv_timer_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_timer_left"
                    android:paddingTop="2dp"
                    android:paddingEnd="3dp"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="定时开/关"
                    android:textColor="@color/color_selector_budget_btn"
                    android:textSize="13dp" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/btn_budget"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:background="@drawable/selector_item_btn"
                android:gravity="center"
                android:orientation="vertical"
                >
                <TextView
                    android:id="@+id/tv_budget_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12dp"
                    android:textColor="@color/color_selector_budget_btn"
                    android:text="预算"
                    />
                <TextView
                    android:id="@+id/tv_budget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11dp"
                    android:textColor="@color/color_selector_budget_text"
                    tools:text="$12"
                    />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</layout>
