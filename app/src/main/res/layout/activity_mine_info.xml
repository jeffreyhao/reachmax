<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:ignore="MissingDefaultResource"
    >
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        >
        <View
            android:layout_width="match_parent"
            android:layout_height="0.33dp"
            android:background="@color/divider_line_color"
            />
        <RelativeLayout
            android:id="@+id/name_layout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginHorizontal="30dp"
            android:paddingBottom="15dp"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用户名"
                android:layout_centerVertical="true"
                android:textColor="@color/pp_color_333333"
                android:textSize="15dp"
                />
            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                tools:text="用户名"
                android:textColor="@color/pp_color_999999"
                android:textSize="15dp"
                />
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/state_layout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginHorizontal="30dp"
            android:paddingBottom="15dp"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="状态"
                android:layout_centerVertical="true"
                android:textColor="@color/pp_color_333333"
                android:textSize="15dp"
                />
            <TextView
                android:id="@+id/tv_user_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="正常"
                android:textColor="@color/pp_color_999999"
                android:textSize="15dp"
                />
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/time_layout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginHorizontal="30dp"
            android:paddingBottom="15dp"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="最后登录时间"
                android:layout_centerVertical="true"
                android:textColor="@color/pp_color_333333"
                android:textSize="15dp"
                />
            <TextView
                android:id="@+id/tv_latest_login_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                tools:text="2024-11-04"
                android:textColor="@color/pp_color_999999"
                android:textSize="15dp"
                />
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/version_layout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginHorizontal="30dp"
            android:paddingBottom="15dp"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="版本号"
                android:layout_centerVertical="true"
                android:textColor="@color/pp_color_333333"
                android:textSize="15dp"
                />
            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:textColor="@color/pp_color_999999"
                android:textSize="15dp"
                tools:text="1.1.0"
                />
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/env_layout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginHorizontal="30dp"
            android:paddingBottom="15dp"
            android:visibility="gone"
            tools:visibility="visible"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Host"
                android:layout_centerVertical="true"
                android:textColor="@color/pp_color_333333"
                android:textSize="15dp"
                />
            <TextView
                android:id="@+id/tv_env"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:textColor="@color/pp_color_999999"
                android:textSize="15dp"
                />
        </RelativeLayout>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            >
            <TextView
                android:id="@+id/tv_logout"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginHorizontal="30dp"
                android:layout_marginBottom="90dp"
                android:layout_gravity="bottom"
                android:gravity="center"
                android:background="@drawable/bg_mine_logout"
                android:textColor="@color/white"
                android:textSize="15dp"
                android:text="退出"
                />
        </FrameLayout>
    </LinearLayout>
</layout>
