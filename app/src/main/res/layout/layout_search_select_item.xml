<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/search_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_transparent_press"
    >
    <com.baidu.baselibrary.widget.CheckBox
        android:id="@+id/search_item_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="5dp"
        android:layout_marginTop="12dp"
        android:textColor="@color/color_selector_check_box"
        android:textSize="13dp"
        tools:checked="true"
        />
    <TextView
        android:id="@+id/search_item_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="10dp"
        android:paddingVertical="5dp"
        android:background="@drawable/bg_transparent_press"
        android:ellipsize="end"
        android:textColor="@color/color_title_black"
        android:textSize="14dp"
        tools:text="Panda-ZT-NovelNook-1054-温Zhe-直投直投直投-ZT-NovelNook-1054-温Zhe-直投"
        />
    <TextView
        android:id="@+id/search_item_Id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_below="@+id/search_item_name"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="15dp"
        android:singleLine="true"
        android:ellipsize="end"
        android:textColor="@color/pp_color_666666"
        android:textSize="13dp"
        tools:text="12467563574623467347"
        />
    <View
        android:id="@+id/multi_btn_line"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginHorizontal="15dp"
        android:layout_below="@+id/search_item_Id"
        android:background="@drawable/bg_discover_top_divider"
        />
</RelativeLayout>
