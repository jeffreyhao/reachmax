<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:paddingLeft="12dp"
    tools:elevation="5dp"
    >

    <TextView
        android:id="@+id/tv_select_accounts"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_marginVertical="12dp"
        android:paddingHorizontal="10dp"
        android:background="@drawable/selector_adv_state"
        android:gravity="center"
        android:textColor="@color/color_selector_level_state"
        android:textSize="12dp"
        android:text="1个广告账户"
        />
    <ImageView
        android:id="@+id/iv_account_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@+id/tv_select_accounts"
        android:layout_marginLeft="-12dp"
        android:padding="6dp"
        android:src="@drawable/ic_select_close"
        />

    <ImageView
        android:id="@+id/iv_left_interval"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="7dp"
        android:layout_toRightOf="@+id/tv_select_accounts"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_select_interval"
        />

    <TextView
        android:id="@+id/tv_select_serial"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_toRightOf="@+id/iv_left_interval"
        android:paddingHorizontal="10dp"
        android:layout_marginVertical="12dp"
        android:background="@drawable/selector_adv_state"
        android:gravity="center"
        android:textColor="@color/color_selector_level_state"
        android:textSize="12dp"
        tools:text="1个广告系列"
        />
    <ImageView
        android:id="@+id/iv_serial_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@+id/tv_select_serial"
        android:layout_marginLeft="-12dp"
        android:padding="6dp"
        android:src="@drawable/ic_select_close"
        />

    <ImageView
        android:id="@+id/iv_right_interval"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="7dp"
        android:layout_toRightOf="@+id/tv_select_serial"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_select_interval"
        />

    <TextView
        android:id="@+id/tv_select_group"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_toRightOf="@+id/iv_right_interval"
        android:paddingHorizontal="10dp"
        android:layout_marginVertical="12dp"
        android:background="@drawable/selector_adv_state"
        android:gravity="center"
        android:textColor="@color/color_selector_level_state"
        android:textSize="12dp"
        tools:text="1个广告组"
        />
    <ImageView
        android:id="@+id/iv_group_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@+id/tv_select_group"
        android:layout_marginLeft="-12dp"
        android:padding="6dp"
        android:src="@drawable/ic_select_close"
        />
    <TextView
        android:id="@+id/tv_select_clear"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="8dp"
        android:paddingHorizontal="12dp"
        android:gravity="center"
        android:textColor="#FE5D5D"
        android:textSize="12dp"
        android:text="清除"
        />

</RelativeLayout>