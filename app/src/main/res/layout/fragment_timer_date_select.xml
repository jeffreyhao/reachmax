<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:ignore="MissingDefaultResource">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/radius_ffffff_corner_top_12dp"
        tools:layout_gravity="bottom"
        tools:elevation="10dp"
        >
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginVertical="16dp"
            android:textColor="@color/black"
            android:textSize="16dp"
            android:text="定时器设置"
            />
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_below="@+id/tv_title"
            android:background="@color/divider_line_color"
            />
        <LinearLayout
            android:id="@+id/layout_select"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_below="@+id/divider"
            android:gravity="center"
            >
            <com.loper7.date_time_picker.DateTimePicker
                android:id="@+id/picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:dt_showLabel="true"
                app:dt_textBold="false"
                app:dt_selectedTextBold="true"
                app:dt_dividerColor="@color/transparent"
                app:dt_textColor="@color/pp_color_666666"
                app:dt_themeColor="@color/black"
                app:dt_normalTextSize="14dp"
                app:dt_selectTextSize="16dp"
                />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_below="@+id/layout_select"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="25dp"
            >
            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:background="@drawable/selector_button_box_press"
                android:gravity="center"
                android:textSize="13dp"
                android:textColor="@color/pp_color_666666"
                android:text="取消"
                />
            <TextView
                android:id="@+id/btn_submit"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/selector_radius_button_press"
                android:gravity="center"
                android:textSize="13dp"
                android:textColor="@color/white"
                android:text="确定"
                />
        </LinearLayout>
    </RelativeLayout>
</layout>
