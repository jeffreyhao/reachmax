<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    >
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        >
        <com.xcyh.reachmax.adv.search.HomeSearchBar
            android:id="@+id/search_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height_search_bar"
            />
        <LinearLayout
            android:id="@+id/content_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/height_search_bar"
            android:layout_marginBottom="@dimen/height_search_shadow"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible"
            >
            <com.baidu.baselibrary.widget.AutoLoadRecyclerView
                android:id="@+id/search_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:paddingBottom="65dp"
                android:background="@color/white"
                android:overScrollMode="never"
                android:scrollbars="none"
                tools:itemCount="10"
                tools:listitem="@layout/layout_search_result_item"
                />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:layout_marginTop="-65dp"
                >
                <View
                    android:id="@+id/multi_btn_line"
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@drawable/bg_discover_top_divider"
                    />
                <LinearLayout
                    android:id="@+id/multi_btn_layout"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_gravity="bottom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="15dp"
                    android:background="@color/white"
                    >
                    <TextView
                        android:id="@+id/multi_btn_cancel"
                        android:layout_width="0dp"
                        android:layout_height="39dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/selector_button_box_press"
                        android:gravity="center"
                        android:textSize="13dp"
                        android:textColor="@color/pp_color_666666"
                        android:text="取消"
                        />
                    <TextView
                        android:id="@+id/multi_btn_submit"
                        android:layout_width="0dp"
                        android:layout_height="39dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/selector_radius_button_press"
                        android:gravity="center"
                        android:textSize="13dp"
                        android:textColor="@color/white"
                        android:text="确认"
                        />
                </LinearLayout>
            </FrameLayout>
            <View
                android:id="@+id/search_shadow_top"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/shadow_mask"
                tools:background="#aaf"
                />
        </LinearLayout>
        <View
            android:id="@+id/search_shadow"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height_search_shadow"
            android:layout_gravity="bottom"
            android:background="@color/shadow_mask"
            android:visibility="gone"
            tools:visibility="visible"
            tools:background="#6666"
            />
    </FrameLayout>

</layout>