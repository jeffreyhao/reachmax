<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:ignore="ResourceName, SpUsage, ContentDescription"
    >
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:background="#fff"
        tools:elevation="10dp"
        tools:layout_marginTop="10dp"
        >
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:padding="15dp"
            android:background="@drawable/radius_white_8dp"
            >
            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="任务名称"
                />
            <TextView
                android:id="@+id/tv_task_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="80dp"
                android:layout_marginEnd="50dp"
                android:layout_marginBottom="15dp"
                android:textSize="14dp"
                android:textColor="@color/pp_color_999999"
                tools:text="Panda-ZT-NovelNook-1021-温Zhe-直投-黎莉莉-20241107"
                />
            <TextView
                android:id="@+id/tv_state"
                android:layout_width="45dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="10dp"
                tools:background="@drawable/bg_task_state_unplayed"
                tools:text="已完成"
                />
            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_task_name"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="动作类型"
                />
            <TextView
                android:id="@+id/tv_action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_task_name"
                android:layout_marginStart="80dp"
                android:layout_marginEnd="50dp"
                android:layout_marginBottom="15dp"
                android:textSize="14dp"
                android:textColor="@color/pp_color_999999"
                tools:text="开启投放"
                />
            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_action"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="时区"
                />
            <TextView
                android:id="@+id/task_timezone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_action"
                android:layout_marginStart="80dp"
                android:layout_marginEnd="50dp"
                android:layout_marginBottom="15dp"
                android:textSize="14dp"
                android:textColor="@color/pp_color_999999"
                android:text="时区"
                />
            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/task_timezone"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="定时器类型"
                />
            <TextView
                android:id="@+id/task_timer_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/task_timezone"
                android:layout_marginStart="80dp"
                android:layout_marginEnd="50dp"
                android:layout_marginBottom="15dp"
                android:textSize="14dp"
                android:textColor="@color/pp_color_999999"
                android:text="一次性"
                />
            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/task_timer_type"
                android:textColor="@color/black"
                android:textSize="13dp"
                android:text="时间设置"
                />
            <TextView
                android:id="@+id/tv_time_setting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/task_timer_type"
                android:layout_marginStart="80dp"
                android:layout_marginEnd="50dp"
                android:layout_marginBottom="5dp"
                android:textSize="14dp"
                android:textColor="@color/pp_color_999999"
                tools:text="2024-11-07  16:34:00"
                />
            <TextView
                android:id="@+id/btn_cancel_task"
                android:layout_width="82dp"
                android:layout_height="30dp"
                android:layout_alignParentEnd="true"
                android:layout_below="@+id/tv_time_setting"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/bg_task_btn"
                android:gravity="center"
                android:textSize="13dp"
                android:textColor="@color/colorAccent"
                android:text="取消任务"
                />
        </RelativeLayout>
        <View
            android:id="@+id/item_task_divider"
            android:layout_width="wrap_content"
            android:layout_height="0.67dp"
            android:background="@color/divider_line_color"
            />
    </FrameLayout>
</layout>
